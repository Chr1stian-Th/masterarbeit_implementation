  <data key="d0">Criminal Offence</data>
  <data key="d1">concept</data>
  <data key="d2">A criminal offence is an action that violates the law and can be subject to investigation and prosecution.</data>
  <data key="d3">chunk-62c64f05f2da893351ea92b9eac1c889</data>
