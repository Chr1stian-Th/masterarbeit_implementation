  <data key="d1">person</data>
  <data key="d2">Rightsholders are individuals or entities that hold rights over works or subject matter and have the authority to authorize or deny the use of such content.</data>
  <data key="d3">chunk-e128fa4453175248aac2b8414bc17643</data>
  <data key="d4">unknown_source</data>
