  <data key="d0">OJ L 277</data>
  <data key="d1">other</data>
  <data key="d2">OJ L 277 refers to the Official Journal L277 where the Digital Services Act was published on 27.10.2022.</data>
  <data key="d3">chunk-df495629e0a16630b58b47ba83c27efa</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019218</data>
