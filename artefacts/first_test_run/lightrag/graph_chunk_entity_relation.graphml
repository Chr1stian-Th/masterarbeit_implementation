<node id="natural persons">
  <data key="d0">natural persons</data>
  <data key="d1">concept</data>
  <data key="d2">Natural persons are individuals whose personal data is subject to processing under the regulations mentioned.&lt;SEP&gt;Natural persons refer to human beings, particularly in the context of data processing and AI assessments.</data>
  <data key="d3">chunk-9b63383abdca30a6a477ed963f4766dc&lt;SEP&gt;chunk-5d37ffab0584c5106298892733e2c26d</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019191</data>
