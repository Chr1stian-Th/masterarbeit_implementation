</node>
<node id="competent authorities">
  <data key="d0">competent authorities</data>
  <data key="d1">organization</data>
  <data key="d2">Competent authorities are public bodies authorized to process personal data for specific legal and regulatory purposes.</data>
  <data key="d3">chunk-9b63383abdca30a6a477ed963f4766dc</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018988</data>
  <data key="d6"></data>
</node>
<node id="Article 21">
  <data key="d0">Article 21</data>
  <data key="d1">content</data>
  <data key="d2">Article 21 provides specific conditions under which a Data Subject can object to the processing of their personal data.&lt;SEP&gt;Article 21 grants the right to object to the processing of personal data based on individual circumstances.</data>
  <data key="d3">chunk-2016931a6e14615018d3d7f8304b6a1e&lt;SEP&gt;chunk-9d92eec8ceb3813d55e2b578c5604f24</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018988</data>
  <data key="d6"></data>
</node>
<node id="Article 16">
  <data key="d0">Article 16</data>
  <data key="d1">concept</data>
  <data key="d2">Article 16 outlines the right of the Data Subject to request the rectification of inaccurate personal data.&lt;SEP&gt;Article 16 pertains to the restrictions on processing personal data disclosed to recipients.&lt;SEP&gt;Article 16 details the obligations of providers of high-risk AI systems, including compliance and documentation requirements.&lt;SEP&gt;Article 16 outlines the obligations of providers concerning high-risk AI systems under the regulation.&lt;SEP&gt;Article 16 outlines obligations for providers regarding their responsibilities within a specified regulatory framework.&lt;SEP&gt;Article 16 specifies obligations of providers in relation to compliance within the regulatory framework set by the European Union.</data>
  <data key="d3">chunk-2016931a6e14615018d3d7f8304b6a1e&lt;SEP&gt;chunk-9d92eec8ceb3813d55e2b578c5604f24&lt;SEP&gt;chunk-e20d35aae57ccfd5ec58ef7772f98c17&lt;SEP&gt;chunk-7f5283f6c8ea50d5bcac79684f773610&lt;SEP&gt;chunk-b45385ec456bd2744fcc58cd02368fc0&lt;SEP&gt;chunk-c3976a157910b9837b3b68c158c5b6b9</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019200</data>
  <data key="d6"></data>
</node>
<node id="Article 17">
  <data key="d0">Article 17</data>
  <data key="d1">event</data>
  <data key="d2">Article 17 details the conditions under which the Data Subject can request erasure of their personal data.&lt;SEP&gt;Article 17 pertains to the establishment of a quality management system for high-risk AI systems, detailing compliance and documentation requirements.&lt;SEP&gt;Article 17 outlines specific requirements for quality management systems that must be adhered to by providers.</data>
  <data key="d3">chunk-2016931a6e14615018d3d7f8304b6a1e&lt;SEP&gt;chunk-3ca50c2792c184b300a7d258f980e38c&lt;SEP&gt;chunk-d08b2a930ede07e77c7cc4f29016fc57</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019201</data>
  <data key="d6"></data>
</node>
<node id="Processing">
  <data key="d0">Processing</data>
  <data key="d1">concept</data>
  <data key="d2">Processing refers to any operation performed on personal data, including collection, storage, use, and destruction.&lt;SEP&gt;Processing refers to any operation or set of operations carried out on personal data, including collection, storage, and use.</data>
  <data key="d3">chunk-2016931a6e14615018d3d7f8304b6a1e&lt;SEP&gt;chunk-7e5e9be572ec001588771fa74ce45258&lt;SEP&gt;chunk-4816e09d93a70dec7bd3be2be787d180</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018988</data>
  <data key="d6"></data>
</node>
<node id="Erasure">
  <data key="d0">Erasure</data>
  <data key="d1">concept</data>
  <data key="d2">Erasure is the act of permanently deleting or removing personal data from processing in accordance with regulations.</data>
  <data key="d3">chunk-2016931a6e14615018d3d7f8304b6a1e</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018988</data>
  <data key="d6"></data>
</node>
<node id="Restriction of Processing">
  <data key="d0">Restriction of Processing</data>
  <data key="d1">concept</data>
  <data key="d2">Restriction of processing means marking stored personal data to limit future processing.&lt;SEP&gt;Restriction of Processing is a legal right that allows the Data Subject to limit the way their personal data is used.</data>
  <data key="d3">chunk-2016931a6e14615018d3d7f8304b6a1e&lt;SEP&gt;chunk-7e5e9be572ec001588771fa74ce45258</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018988</data>
  <data key="d6"></data>
</node>
<node id="Democratic Society">
  <data key="d0">Democratic Society</data>
  <data key="d1">concept</data>
  <data key="d2">A democratic society aims to safeguard important interests such as public security and the prevention of crime, ensuring the rights of individuals are maintained.</data>
  <data key="d3">chunk-eb2f14226b252ba13becf59370a070e3</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018988</data>
  <data key="d6"></data>
</node>
<node id="Directive 2000/31/EC">
  <data key="d0">Directive 2000/31/EC</data>
  <data key="d1">content</data>
  <data key="d2">Directive 2000/31/EC outlines the legal aspects of information society services, particularly focusing on electronic commerce within the internal market.</data>
  <data key="d3">chunk-eb2f14226b252ba13becf59370a070e3</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018988</data>
  <data key="d6"></data>
</node>
<node id="Judicial Authorities">
  <data key="d0">Judicial Authorities</data>
  <data key="d1">organization</data>
  <data key="d2">Judicial authorities are institutions responsible for the administration of justice, including courts and legal systems.&lt;SEP&gt;Judicial authorities are independent entities whose decisions are binding on requests for authorizations concerning AI systems as described in the text.</data>
  <data key="d3">chunk-eb2f14226b252ba13becf59370a070e3&lt;SEP&gt;chunk-3642f938e14bfed60a5d5b5fdc383e38</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019188</data>
  <data key="d6"></data>
</node>
<node id="Forensic Laboratories">
  <data key="d0">Forensic Laboratories</data>
  <data key="d1">organization</data>
  <data key="d2">Forensic laboratories are facilities that support the investigation and detection of criminal offences through scientific analysis and evidence processing.</data>
  <data key="d3">chunk-eb2f14226b252ba13becf59370a070e3</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018988</data>
  <data key="d6"></data>
</node>
<node id="Article 6">
  <data key="d0">Article 6</data>
  <data key="d1">document</data>
  <data key="d2">Article 6 specifies conditions under which data processing is considered lawful, detailing the necessary circumstances for obtaining consent or fulfilling obligations.&lt;SEP&gt;Article 6 refers to specific provisions within data protection regulations that outline lawful bases for processing personal data, including legitimate interests and consent.&lt;SEP&gt;Article 6 references specific regulations regarding delegated powers and compliance within the framework of EU legislation.&lt;SEP&gt;Article 6 outlines the conditions under which an AI system is considered to be not-high-risk, providing criteria for registration.</data>
  <data key="d3">chunk-e144d059e01c4df4d2fdb9406d31751d&lt;SEP&gt;chunk-9355b1cd3c48988b8332485ef99af2c3&lt;SEP&gt;chunk-7f5283f6c8ea50d5bcac79684f773610&lt;SEP&gt;chunk-0d2a58a86edb7bec623750da3d232aa2</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019202</data>
  <data key="d6"></data>
</node>
<node id="Article 22">
  <data key="d0">Article 22</data>
  <data key="d1">concept</data>
  <data key="d2">Article 22 provides the right against automated individual decision-making, including profiling and its implications.&lt;SEP&gt;Article 22 addresses automated decision-making and profiling in the context of data protection, providing rights for data subjects regarding these processes.&lt;SEP&gt;Article 22 pertains to the rights of data subjects in relation to automated processing and decision-making.&lt;SEP&gt;Article 22 specifies the obligations of authorized representatives, indicating regulatory duties.&lt;SEP&gt;Article 22 outlines obligations for authorized representatives under the enforcement of EU regulations.</data>
  <data key="d3">chunk-e144d059e01c4df4d2fdb9406d31751d&lt;SEP&gt;chunk-9d92eec8ceb3813d55e2b578c5604f24&lt;SEP&gt;chunk-c22927198decad5ee173ab2f05d62983&lt;SEP&gt;chunk-7f5283f6c8ea50d5bcac79684f773610&lt;SEP&gt;chunk-b45385ec456bd2744fcc58cd02368fc0</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019201</data>
  <data key="d6"></data>
</node>
<node id="Relevant And Reasoned Objection">
  <data key="d0">Relevant And Reasoned Objection</data>
  <data key="d1">concept</data>
  <data key="d2">Relevant and reasoned objection refers to a formal objection to a draft decision concerning the infringement of regulations affecting data subjects' rights and freedoms.</data>
  <data key="d3">chunk-9355b1cd3c48988b8332485ef99af2c3</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018988</data>
  <data key="d6"></data>
</node>
<node id="Information Society Service">
  <data key="d0">Information Society Service</data>
  <data key="d1">concept</data>
  <data key="d2">Information society service is defined in the context of the EU Directive 2015/1535 as a service that falls under specific regulations for technical standards and rules.</data>
  <data key="d3">chunk-9355b1cd3c48988b8332485ef99af2c3</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018988</data>
  <data key="d6"></data>
</node>
<node id="International Organisation">
  <data key="d0">International Organisation</data>
  <data key="d1">concept</data>
  <data key="d2">An international organisation is defined as a group governed by public international law, including its subordinate bodies, formed by agreement between multiple countries.&lt;SEP&gt;An International Organisation is a body that crosses national boundaries, often involved in compliance with data protection and other international agreements.&lt;SEP&gt;An International Organisation is a body established by multiple countries to engage in cooperative activities, which may include data processing.&lt;SEP&gt;International Organisation refers to entities established by treaty or other agreements between nations that may receive personal data under certain conditions.</data>
  <data key="d3">chunk-9355b1cd3c48988b8332485ef99af2c3&lt;SEP&gt;chunk-66f1f525b011c8f0bfb14ba0891419e3&lt;SEP&gt;chunk-5ab41d6ec0d1446be5ba58c1ab5b423c&lt;SEP&gt;chunk-5b3266fc2be81fd61dcffc1afc41700b</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018988</data>
  <data key="d6"></data>
</node>
<node id="Directive (EU) 2015/1535">
  <data key="d0">Directive (EU) 2015/1535</data>
  <data key="d1">document</data>
  <data key="d2">Directive (EU) 2015/1535 is a piece of legislation from the European Parliament and the Council that lays down procedures for providing information related to technical regulations and information society services.</data>
  <data key="d3">chunk-9355b1cd3c48988b8332485ef99af2c3</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018988</data>
  <data key="d6"></data>
</node>
<node id="Data Protection Framework">
  <data key="d0">Data Protection Framework</data>
  <data key="d1">concept</data>
  <data key="d2">The data protection framework comprises laws and regulations in the Union aimed at safeguarding personal data rights and ensuring compliance.</data>
  <data key="d3">chunk-9403aaca1e6e92e51844c1b1175b373b</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018988</data>
  <data key="d6"></data>
</node>
<node id="Rights of Data Subjects">
  <data key="d0">Rights of Data Subjects</data>
  <data key="d1">concept</data>
  <data key="d2">Rights of data subjects refer to the entitlements and protections granted to individuals regarding their personal data under data protection laws.</data>
  <data key="d3">chunk-9403aaca1e6e92e51844c1b1175b373b</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018988</data>
  <data key="d6"></data>
</node>
<node id="Obligations of Data Processors">
  <data key="d0">Obligations of Data Processors</data>
  <data key="d1">concept</data>
  <data key="d2">Obligations of data processors encompass the responsibilities and duties imposed on entities that process personal data, ensuring compliance with relevant regulations.</data>
  <data key="d3">chunk-9403aaca1e6e92e51844c1b1175b373b</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018988</data>
  <data key="d6"></data>
</node>
<node id="Articles 15 to 22">
  <data key="d0">Articles 15 to 22</data>
  <data key="d1">concept</data>
  <data key="d2">Articles 15 to 22 outline the rights of the Data Subject and conditions under which the Controller must act to protect those rights.</data>
  <data key="d3">chunk-7aa4d903bc5ead1fdb896356fd92fbd5</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018988</data>
  <data key="d6"></data>
</node>
<node id="Articles 13 and 14">
  <data key="d0">Articles 13 and 14</data>
  <data key="d1">concept</data>
  <data key="d2">Articles 13 and 14 require the Controller to provide certain information to the Data Subject regarding data collection and processing methods.</data>
  <data key="d3">chunk-7aa4d903bc5ead1fdb896356fd92fbd5</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018988</data>
  <data key="d6"></data>
</node>
<node id="Judicial Remedy">
  <data key="d0">Judicial Remedy</data>
  <data key="d1">concept</data>
  <data key="d2">Judicial Remedy refers to the legal recourse available to a Data Subject if the Controller does not act on their requests regarding personal data.</data>
  <data key="d3">chunk-7aa4d903bc5ead1fdb896356fd92fbd5</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018988</data>
  <data key="d6"></data>
</node>
<node id="Standardised Icons">
  <data key="d0">Standardised Icons</data>
  <data key="d1">artifact</data>
  <data key="d2">Standardised Icons are graphical representations intended to provide concise information about data processing in an easily understandable format.</data>
  <data key="d3">chunk-7aa4d903bc5ead1fdb896356fd92fbd5</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018988</data>
  <data key="d6"></data>
</node>
<node id="Article 11">
  <data key="d0">Article 11</data>
  <data key="d1">concept</data>
  <data key="d2">Article 11 outlines specific conditions under which the Controller must operate regarding the identification of the Data Subject making a request.&lt;SEP&gt;Article 11 outlines conditions where processing of personal data does not require identification of the data subject.&lt;SEP&gt;Article 11 outlines procedures related to compliance with standards under Regulation (EU) No 1025/2012.&lt;SEP&gt;Article 11 specifies rules and guidelines regarding the delegation of power and compliance measures within the EU regulatory framework.</data>
  <data key="d3">chunk-7aa4d903bc5ead1fdb896356fd92fbd5&lt;SEP&gt;chunk-40ecaa725d6d1bc748899703ed8b84dc&lt;SEP&gt;chunk-38cdce9b64b40ba40d6acb529d375787&lt;SEP&gt;chunk-7f5283f6c8ea50d5bcac79684f773610</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019195</data>
  <data key="d6"></data>
</node>
<node id="Section 2">
  <data key="d0">Section 2</data>
  <data key="d1">concept</data>
  <data key="d2">Section 2 provides regulations regarding information and access to personal data.&lt;SEP&gt;Section 2 refers to a segment of regulations that outlines the requirements for high-risk AI systems.&lt;SEP&gt;Section 2 refers to a specific part of the Regulation that outlines requirements for notified bodies in relation to AI systems and assessments.&lt;SEP&gt;Section 2 delineates specific requirements for high-risk AI systems and general-purpose AI models.&lt;SEP&gt;Section 2 specifies requirements applicable to high-risk AI systems under evaluation.</data>
  <data key="d3">chunk-8252fb4b704db3adac7bfb7714d3b70f&lt;SEP&gt;chunk-c3976a157910b9837b3b68c158c5b6b9&lt;SEP&gt;chunk-78ea54ae6ffd2850256fb7ad037b8474&lt;SEP&gt;chunk-926dc457d536779e13715d0b813c320d&lt;SEP&gt;chunk-60ded1802882124212402df3d80de903</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019204</data>
  <data key="d6"></data>
</node>
<node id="Article 13">
  <data key="d0">Article 13</data>
  <data key="d1">content</data>
  <data key="d2">Article 13 specifies the required information when personal data is collected from the data subject.&lt;SEP&gt;Article 13 of Directive (EU) 2016/680 outlines obligations pertaining to the use of AI in law enforcement, focusing on the rights of natural persons.&lt;SEP&gt;Article 13 refers to a section of regulation that outlines requirements for the provision of information and training related to high-risk AI systems.&lt;SEP&gt;Article 13 emphasizes the need for transparency and provision of information to deployers of high-risk AI systems.</data>
  <data key="d3">chunk-8252fb4b704db3adac7bfb7714d3b70f&lt;SEP&gt;chunk-92f9c6220442ff06dfe6fe52499f18aa&lt;SEP&gt;chunk-cb73a01a1d9b0ba7ee87eb6d896fbea4&lt;SEP&gt;chunk-358eb1d0b0f35e665a7b23702159cfd5</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019194</data>
  <data key="d6"></data>
</node>
<node id="Article 14">
  <data key="d0">Article 14</data>
  <data key="d1">concept</data>
  <data key="d2">Article 14 outlines the information that must be provided when personal data has not been obtained from the data subject.&lt;SEP&gt;Article 14 outlines the requirements for human oversight of high-risk AI systems, detailing measures for ensuring safety and efficacy.&lt;SEP&gt;Article 14 specifies conditions related to the verification of results associated with high-risk AI systems and the identification of natural persons involved in this process.&lt;SEP&gt;Article 14 refers to a section of regulations outlining human oversight measures for AI systems.</data>
  <data key="d3">chunk-8252fb4b704db3adac7bfb7714d3b70f&lt;SEP&gt;chunk-cb73a01a1d9b0ba7ee87eb6d896fbea4&lt;SEP&gt;chunk-7c2fbe724dee488ea4e437995307241f&lt;SEP&gt;chunk-561d345a761ead6d6e1bfabd0f89e09c</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019198</data>
  <data key="d6"></data>
</node>
<node id="Categories of Personal Data">
  <data key="d0">Categories of Personal Data</data>
  <data key="d1">concept</data>
  <data key="d2">Categories of Personal Data refers to the different types of personal information that may be collected from data subjects not directly.</data>
  <data key="d3">chunk-8252fb4b704db3adac7bfb7714d3b70f</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018989</data>
  <data key="d6"></data>
</node>
<node id="Article 9(1)">
  <data key="d0">Article 9(1)</data>
  <data key="d1">legal_text</data>
  <data key="d2">Article 9(1) contains provisions regarding the processing of special categories of personal data.</data>
  <data key="d3">chunk-274264435e41f5d230030900b38f8c35</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018989</data>
  <data key="d6"></data>
</node>
<node id="Article 10">
  <data key="d0">Article 10</data>
  <data key="d1">concept</data>
  <data key="d2">Article 10 refers to a section of regulation concerning the processing of personal data related to criminal convictions and offenses under the control of official authority.&lt;SEP&gt;Article 10 pertains to the processing of personal data related to criminal convictions and offenses.&lt;SEP&gt;Article 10 of Directive (EU) 2016/680 outlines the conditions for processing biometric data within the context of law enforcement.&lt;SEP&gt;Article 10 is a provision within Directive (EU) 2016/680 related to the processing of biometric data by law enforcement authorities.&lt;SEP&gt;Article 10 refers to a specific provision within Regulation (EU) No 1025/2012 regarding standardisation processes and requests.</data>
  <data key="d3">chunk-274264435e41f5d230030900b38f8c35&lt;SEP&gt;chunk-40ecaa725d6d1bc748899703ed8b84dc&lt;SEP&gt;chunk-358eb1d0b0f35e665a7b23702159cfd5&lt;SEP&gt;chunk-880ccb1f68ffcae0925e238408590ede&lt;SEP&gt;chunk-926dc457d536779e13715d0b813c320d</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019207</data>
  <data key="d6"></data>
</node>
<node id="Article 68">
  <data key="d0">Article 68</data>
  <data key="d1">content</data>
  <data key="d2">Article 68 involves coordination with the Board for data protection regulations.&lt;SEP&gt;Article 68 discusses the formation of a Scientific Panel of Independent Experts to support enforcement related to AI.&lt;SEP&gt;Article 68 specifies the establishment of the scientific panel and the criteria for independent experts.</data>
  <data key="d3">chunk-274264435e41f5d230030900b38f8c35&lt;SEP&gt;chunk-f137cf6069f0720a443c5b5abd0fe3ea&lt;SEP&gt;chunk-d5a5973b039f9a9af3e3e9d93b392c66</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019199</data>
  <data key="d6"></data>
</node>
<node id="Data Breach">
  <data key="d0">Data Breach</data>
  <data key="d1">concept</data>
  <data key="d2">A data breach refers to the unauthorized access or disclosure of personal data, which poses risks to data subjects' rights and freedoms.</data>
  <data key="d3">chunk-df28c0bb060b598df163cc06bf49d0e9</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018989</data>
  <data key="d6"></data>
</node>
<node id="Personal Data Records">
  <data key="d0">Personal Data Records</data>
  <data key="d1">data</data>
  <data key="d2">Personal data records are collections of information concerning data subjects that are affected by data breaches and require protection under data laws.</data>
  <data key="d3">chunk-df28c0bb060b598df163cc06bf49d0e9</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018989</data>
  <data key="d6"></data>
</node>
<node id="Directive 2003/98/EC">
  <data key="d0">Directive 2003/98/EC</data>
  <data key="d1">content</data>
  <data key="d2">Directive 2003/98/EC is a European legal framework concerning the re-use of public sector information while ensuring the protection of personal data.</data>
  <data key="d3">chunk-a0ea41c30759ecd048ab40483ec1605b</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018989</data>
  <data key="d6"></data>
</node>
<node id="Employee Personal Data">
  <data key="d0">Employee Personal Data</data>
  <data key="d1">data</data>
  <data key="d2">Employee personal data pertains to data collected and processed about employees in the context of their employment.</data>
  <data key="d3">chunk-a0ea41c30759ecd048ab40483ec1605b</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018989</data>
  <data key="d6"></data>
</node>
<node id="Archiving Purposes">
  <data key="d0">Archiving Purposes</data>
  <data key="d1">concept</data>
  <data key="d2">Archiving purposes refer to the processing of personal data for maintaining records for historical, scientific, or statistical use.</data>
  <data key="d3">chunk-a0ea41c30759ecd048ab40483ec1605b</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018989</data>
  <data key="d6"></data>
</node>
<node id="Legislative Measure">
  <data key="d0">Legislative Measure</data>
  <data key="d1">concept</data>
  <data key="d2">The Legislative Measure refers to proposed laws that must be adopted by national parliaments, affecting the processing of personal data.</data>
  <data key="d3">chunk-4f71c70521bc1935b4a077373428f4b1</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018989</data>
  <data key="d6"></data>
</node>
<node id="Article 35">
  <data key="d0">Article 35</data>
  <data key="d1">concept</data>
  <data key="d2">Article 35 pertains to the Data Protection Impact Assessment requirements within the data protection regulations.&lt;SEP&gt;Article 35 outlines the requirements for conducting a data protection impact assessment under Regulation (EU) 2016/679.&lt;SEP&gt;Article 35 details the identification numbers and lists of notified bodies that the Commission must maintain.&lt;SEP&gt;Article 35 pertains to regulations for data protection assessments as defined in specific EU directives.</data>
  <data key="d3">chunk-4f71c70521bc1935b4a077373428f4b1&lt;SEP&gt;chunk-fe99ac2ad30ad5f2f6c6c5e2e23456e9&lt;SEP&gt;chunk-78ea54ae6ffd2850256fb7ad037b8474&lt;SEP&gt;chunk-81b13333cc1be55a8f31fdada74da057</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019209</data>
  <data key="d6"></data>
</node>
<node id="Article 17(1)">
  <data key="d0">Article 17(1)</data>
  <data key="d1">concept</data>
  <data key="d2">Article 17(1) involves guidance on obligations related to personal data processing.</data>
  <data key="d3">chunk-9d92eec8ceb3813d55e2b578c5604f24</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018989</data>
  <data key="d6"></data>
</node>
<node id="Article 18">
  <data key="d0">Article 18</data>
  <data key="d1">concept</data>
  <data key="d2">Article 18 outlines the requirements and rights regarding the processing of personal data.&lt;SEP&gt;Article 18 details the documentation requirements for providers of high-risk AI systems and the duration for which documents must be maintained.&lt;SEP&gt;Article 18 outlines procedural rights related to enforcement actions against providers of AI systems.</data>
  <data key="d3">chunk-9d92eec8ceb3813d55e2b578c5604f24&lt;SEP&gt;chunk-9a54b012266e9b9c7302fce6d400f583&lt;SEP&gt;chunk-3ca50c2792c184b300a7d258f980e38c</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019193</data>
  <data key="d6"></data>
</node>
<node id="Article 20">
  <data key="d0">Article 20</data>
  <data key="d1">concept</data>
  <data key="d2">Article 20 establishes the right to data portability for data subjects under certain conditions.&lt;SEP&gt;Article 20 describes the necessary corrective actions required from providers of high-risk AI systems.&lt;SEP&gt;Article 20 of Regulation (EU) 2019/1020 details the responsibilities of national authorities regarding notification of serious incidents.</data>
  <data key="d3">chunk-9d92eec8ceb3813d55e2b578c5604f24&lt;SEP&gt;chunk-80a99ad850f0546ea9da41c8d764b154&lt;SEP&gt;chunk-e20d35aae57ccfd5ec58ef7772f98c17</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019181</data>
  <data key="d6"></data>
</node>
<node id="Legitimate Interests">
  <data key="d0">Legitimate Interests</data>
  <data key="d1">concept</data>
  <data key="d2">Legitimate Interests refer to the grounds for processing personal data based on the interests of the controller or a third party.</data>
  <data key="d3">chunk-ae28521738df7feadad1be4821afc294</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018989</data>
  <data key="d6"></data>
</node>
<node id="Privacy Regulation">
  <data key="d0">Privacy Regulation</data>
  <data key="d1">concept</data>
  <data key="d2">Privacy Regulation refers to legal frameworks governing the processing of personal data and ensuring the protection of individual privacy rights.</data>
  <data key="d3">chunk-ae28521738df7feadad1be4821afc294</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018989</data>
  <data key="d6"></data>
</node>
<node id="Article 7">
  <data key="d0">Article 7</data>
  <data key="d1">document</data>
  <data key="d2">Article 7 outlines specific conditions for obtaining consent from data subjects in relation to personal data processing.&lt;SEP&gt;Article 7 outlines further provisions related to the delegation of powers and operational procedures in the context of EU law.</data>
  <data key="d3">chunk-ae28521738df7feadad1be4821afc294&lt;SEP&gt;chunk-7f5283f6c8ea50d5bcac79684f773610</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019202</data>
