  <data key="d0">Council Framework Decision 2002/584/JHA</data>
  <data key="d1">content</data>
  <data key="d2">Council Framework Decision 2002/584/JHA outlines the procedures for issuing European arrest warrants and regulating cooperation between Member States.</data>
  <data key="d3">chunk-4b4a84f46448cc3a4a1755da273e920e&lt;SEP&gt;chunk-ab5bd61fedb2857e3db189c5f7bb8f94</data>
