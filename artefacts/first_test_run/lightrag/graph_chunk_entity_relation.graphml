  <data key="d0">Scientific Research and Development</data>
  <data key="d1">concept</data>
  <data key="d2">Scientific research and development refers to activities aimed at advancing knowledge and technology, specifically related to AI systems and models.</data>
  <data key="d3">chunk-061f3c307dd55152ffbb5bdfae17ea90</data>
  <data key="d4">unknown_source</data>
