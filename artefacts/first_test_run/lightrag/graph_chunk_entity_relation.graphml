  <data key="d4">unknown_source</data>
  <data key="d5">1773018980</data>
  <data key="d6"></data>
</node>
<node id="National Supervisory Authorities">
  <data key="d0">National Supervisory Authorities</data>
  <data key="d1">organization</data>
  <data key="d2">National Supervisory Authorities are responsible for overseeing the application of the Regulation at a national level.</data>
  <data key="d3">chunk-7d95ad85f86f6e4a4771e8f92b0cbf27</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018980</data>
  <data key="d6"></data>
</node>
<node id="Data Controllers">
  <data key="d0">Data Controllers</data>
  <data key="d1">concept</data>
  <data key="d2">Data controllers are entities that determine how personal data is processed and are obligated to ensure compliance with data protection regulations.&lt;SEP&gt;Data Controllers refer to entities that determine the purposes and means of processing personal data in compliance with Union law.</data>
  <data key="d3">chunk-0085cb3cc5d5dc4d434424e6dab722f3&lt;SEP&gt;chunk-74667d89df5ee6111b7743e86ee4744f</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019217</data>
  <data key="d6"></data>
</node>
<node id="Direct Marketing">
  <data key="d0">Direct Marketing</data>
  <data key="d1">concept</data>
  <data key="d2">Direct marketing encompasses activities aimed at communicating directly with individuals to promote goods or services, which subjects can object to under certain conditions.</data>
  <data key="d3">chunk-0085cb3cc5d5dc4d434424e6dab722f3</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018981</data>
  <data key="d6"></data>
</node>
<node id="Interoperable Format">
  <data key="d0">Interoperable Format</data>
  <data key="d1">method</data>
  <data key="d2">An interoperable format is a structured data format that allows personal data to be easily shared between different controllers.</data>
  <data key="d3">chunk-0085cb3cc5d5dc4d434424e6dab722f3</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018981</data>
