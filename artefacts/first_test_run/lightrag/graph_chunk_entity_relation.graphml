<node id="Official Authorities">
  <data key="d0">Official Authorities</data>
  <data key="d1">organization</data>
  <data key="d2">Official authorities refer to government entities responsible for the lawful processing of personal data under public interest for various administrative purposes.</data>
  <data key="d3">chunk-97d77d4c79204175483320a1c612b93b</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018986</data>
