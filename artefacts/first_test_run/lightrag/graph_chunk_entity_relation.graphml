<node id="Data Governance">
  <data key="d0">Data Governance</data>
  <data key="d1">concept</data>
  <data key="d2">Data governance refers to the management of data availability, usability, integrity, and security in AI systems.&lt;SEP&gt;Data governance involves the management practices and policies relating to the use and integrity of data sets used in high-risk AI systems.</data>
  <data key="d3">chunk-92f9c6220442ff06dfe6fe52499f18aa&lt;SEP&gt;chunk-234952a50b5a02b1afedbe8d8e1c076b</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019194</data>
  <data key="d6"></data>
</node>
<node id="Training Data Sets">
  <data key="d0">Training Data Sets</data>
  <data key="d1">data</data>
  <data key="d2">Training data sets are the data used for teaching high-risk AI systems and must meet specific quality criteria.&lt;SEP&gt;Training Data Sets are the datasets used to train the AI System, essential for its conformity evaluation.</data>
  <data key="d3">chunk-92f9c6220442ff06dfe6fe52499f18aa&lt;SEP&gt;chunk-741b1675a971d075b2d3571148530b89</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019194</data>
  <data key="d6"></data>
</node>
<node id="Validation Data Sets">
  <data key="d0">Validation Data Sets</data>
  <data key="d1">data</data>
  <data key="d2">Validation data sets are used to assess the performance of high-risk AI systems and ensure they meet quality standards.</data>
  <data key="d3">chunk-92f9c6220442ff06dfe6fe52499f18aa</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019194</data>
  <data key="d6"></data>
</node>
<node id="Testing Data Sets">
  <data key="d0">Testing Data Sets</data>
  <data key="d1">data</data>
  <data key="d2">Testing data sets are required for evaluating the functionality and performance of high-risk AI systems in various conditions.</data>
  <data key="d3">chunk-92f9c6220442ff06dfe6fe52499f18aa</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019194</data>
  <data key="d6"></data>
</node>
