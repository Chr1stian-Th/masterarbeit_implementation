<node id="European Union Harmonised Legislation">
  <data key="d0">European Union Harmonised Legislation</data>
  <data key="d1">concept</data>
  <data key="d2">European Union harmonised legislation refers to legal requirements across the EU, ensuring compliance and sectoral law application.</data>
  <data key="d3">chunk-e42c3bff7bd9447d59998364274b31d5</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019195</data>
