  <data key="d0">Withdrawal of an AI System</data>
  <data key="d1">concept</data>
  <data key="d2">Withdrawal of an AI system refers to measures aimed at preventing the AI system from being made available on the market.</data>
  <data key="d3">chunk-5e14a05a776d89b0f172b0c5789b0936</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019224</data>
  <data key="d6"></data>
</node>
<node id="Performance of an AI System">
  <data key="d0">Performance of an AI System</data>
  <data key="d1">concept</data>
  <data key="d2">Performance of an AI system is the ability to achieve its intended purpose.</data>
  <data key="d3">chunk-5e14a05a776d89b0f172b0c5789b0936</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019224</data>
  <data key="d6"></data>
</node>
<node id="Substantial Modification">
  <data key="d0">Substantial Modification</data>
  <data key="d1">concept</data>
  <data key="d2">Substantial modification involves changes to an AI system impacting its compliance or intended purpose after market release.</data>
  <data key="d3">chunk-5e14a05a776d89b0f172b0c5789b0936</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019224</data>
  <data key="d6"></data>
</node>
