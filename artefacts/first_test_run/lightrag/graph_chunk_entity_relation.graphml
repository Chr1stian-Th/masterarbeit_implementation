<node id="Article 29">
  <data key="d0">Article 29</data>
  <data key="d1">concept</data>
  <data key="d2">Article 29 outlines the requirements and procedures related to accreditation certificates for conformity assessment bodies.&lt;SEP&gt;Article 29 describes the application process for conformity assessment bodies seeking notification.</data>
  <data key="d3">chunk-fe99ac2ad30ad5f2f6c6c5e2e23456e9&lt;SEP&gt;chunk-1d997baeb2a2ac2118ac1e3e19dfcf16</data>
