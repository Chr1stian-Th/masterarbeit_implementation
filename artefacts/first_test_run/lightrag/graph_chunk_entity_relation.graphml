<node id="Implementing Act">
  <data key="d0">Implementing Act</data>
  <data key="d1">method</data>
  <data key="d2">An Implementing Act is a legal procedure by which the Commission assesses and decides on the adequacy of data protection in third countries.</data>
  <data key="d3">chunk-66f1f525b011c8f0bfb14ba0891419e3</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018991</data>
