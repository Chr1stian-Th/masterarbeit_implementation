<node id="Testing and Experimentation Facilities">
  <data key="d0">Testing and Experimentation Facilities</data>
  <data key="d1">organization</data>
  <data key="d2">Testing and Experimentation Facilities are established to provide access and support for technical and scientific evaluation under the Regulation.</data>
  <data key="d3">chunk-15ddf6f50e7dd1750489a4999454bcdf</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019218</data>
