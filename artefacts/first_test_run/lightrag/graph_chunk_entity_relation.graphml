<node id="Regulation (EC) No 45/2001">
  <data key="d0">Regulation (EC) No 45/2001</data>
  <data key="d1">data</data>
  <data key="d2">Regulation (EC) No 45/2001 pertains to the processing of personal data by Union institutions and agencies within the European framework.</data>
  <data key="d3">chunk-9b63383abdca30a6a477ed963f4766dc</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018987</data>
