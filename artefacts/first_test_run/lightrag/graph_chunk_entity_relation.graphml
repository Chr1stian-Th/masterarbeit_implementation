</node>
<node id="Union Ethical Guidelines">
  <data key="d0">Union Ethical Guidelines</data>
  <data key="d1">concept</data>
  <data key="d2">Union Ethical Guidelines outline principles for ensuring trustworthy AI, addressing objectives such as minimizing environmental impact and promoting inclusivity.</data>
  <data key="d3">chunk-b75f7d42df244a78773a748afb4f421f</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019201</data>
  <data key="d6"></data>
</node>
<node id="Environmental Sustainability">
  <data key="d0">Environmental Sustainability</data>
  <data key="d1">concept</data>
  <data key="d2">Environmental sustainability involves minimizing the negative impact of AI systems on the environment through energy-efficient programming and design techniques.</data>
  <data key="d3">chunk-b75f7d42df244a78773a748afb4f421f</data>
  <data key="d4">unknown_source</data>
