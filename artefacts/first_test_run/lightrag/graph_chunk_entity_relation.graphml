<node id="Digital Services Act">
  <data key="d0">Digital Services Act</data>
  <data key="d1">concept</data>
  <data key="d2">The Digital Services Act establishes regulations concerning digital services, particularly focusing on biometric categorization and identification.</data>
  <data key="d3">chunk-df495629e0a16630b58b47ba83c27efa</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019218</data>
  <data key="d6"></data>
</node>
<node id="Real-Time Systems">
  <data key="d0">Real-Time Systems</data>
  <data key="d1">concept</data>
  <data key="d2">Real-time systems capture and process biometric data instantaneously, often using live video footage for identification.</data>
  <data key="d3">chunk-df495629e0a16630b58b47ba83c27efa</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019218</data>
  <data key="d6"></data>
</node>
<node id="Post Systems">
  <data key="d0">Post Systems</data>
  <data key="d1">concept</data>
  <data key="d2">Post systems involve biometric data capture at one time, with identification occurring later, often using previously recorded footage.</data>
  <data key="d3">chunk-df495629e0a16630b58b47ba83c27efa</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019218</data>
  <data key="d6"></data>
