<node id="Facial Recognition Databases">
  <data key="d0">Facial Recognition Databases</data>
  <data key="d1">concept</data>
  <data key="d2">Facial recognition databases are collections of facial images used by AI systems to identify individuals, which are subject to regulation.&lt;SEP&gt;Facial recognition databases are collections of facial images compiled for use in identification and categorization of individuals.</data>
  <data key="d3">chunk-62c64f05f2da893351ea92b9eac1c889&lt;SEP&gt;chunk-00803764d58d840979922e38d1dc555c</data>
