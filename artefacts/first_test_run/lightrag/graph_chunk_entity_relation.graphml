  <data key="d0">Directive 2011/24/EU</data>
  <data key="d1">content</data>
  <data key="d2">Directive 2011/24/EU is a legislative document from the European Parliament focusing on patients' rights in cross-border healthcare.</data>
  <data key="d3">chunk-8e3626adc7cf865bec83f6479c1e08cb</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018987</data>
