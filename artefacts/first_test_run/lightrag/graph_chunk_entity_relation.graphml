  <data key="d1">concept</data>
  <data key="d2">Recall of an AI system involves measures taken to return the system to the provider or disable its use after it has been deployed.</data>
  <data key="d3">chunk-5e14a05a776d89b0f172b0c5789b0936</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019224</data>
  <data key="d6"></data>
</node>
