</edge>
<edge source="Data Subject" target="Consent">
  <data key="d7">2.0</data>
  <data key="d8">Data subjects have the right to give consent regarding the processing of their personal data.&lt;SEP&gt;Consent signifies a data subject's agreement to the processing of their personal data.</data>
  <data key="d9">data processing,data processing agreement,rights</data>
  <data key="d10">chunk-f4dfe3f1190ff8cf7dc9f62b85bed40a&lt;SEP&gt;chunk-7e5e9be572ec001588771fa74ce45258</data>
