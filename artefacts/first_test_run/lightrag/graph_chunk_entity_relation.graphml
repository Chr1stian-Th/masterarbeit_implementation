<node id="Historical Research">
  <data key="d0">Historical Research</data>
  <data key="d1">concept</data>
  <data key="d2">Historical research focuses on studying and understanding events that occurred in the past, including genealogical research, while adhering to certain regulations regarding personal data.</data>
  <data key="d3">chunk-6ce0488d21ac5956f37974d7ae0799b4</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018990</data>
