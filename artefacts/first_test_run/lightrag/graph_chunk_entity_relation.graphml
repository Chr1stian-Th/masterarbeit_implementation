  <data key="d4">unknown_source</data>
  <data key="d5">1773018990</data>
  <data key="d6"></data>
</node>
<node id="National Accreditation Body">
  <data key="d0">National Accreditation Body</data>
  <data key="d1">organization</data>
  <data key="d2">The national accreditation body is responsible for revoking the accreditation of certification bodies if they do not meet the necessary conditions set out in regulations.&lt;SEP&gt;The National Accreditation Body is referenced as the entity responsible for conducting assessments and monitoring under specific regulations.</data>
  <data key="d3">chunk-a4fb6b788c6bc23206d8cd996c5a6a6b&lt;SEP&gt;chunk-fe99ac2ad30ad5f2f6c6c5e2e23456e9</data>
  <data key="d4">unknown_source</data>
