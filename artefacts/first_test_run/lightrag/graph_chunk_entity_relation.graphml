<node id="Children">
  <data key="d0">Children</data>
  <data key="d1">concept</data>
  <data key="d2">Children are individuals under the age of consent, whose personal data must be protected especially when it comes to marketing and profile creation.&lt;SEP&gt;Children are considered vulnerable natural persons whose personal data processing requires special care and attention under regulations.</data>
  <data key="d3">chunk-bd97dcdb68144953a81ad8ba7d8f52b0&lt;SEP&gt;chunk-35884c5ef57faf321ff9fce99bd2d970</data>
