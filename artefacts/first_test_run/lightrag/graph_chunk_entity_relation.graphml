  <data key="d0">Statistical Offices of the European Communities</data>
  <data key="d1">organization</data>
  <data key="d2">The Statistical Offices of the European Communities is responsible for collecting and disseminating statistical data within the EU.</data>
  <data key="d3">chunk-87ae75b9888750c7d94cfda6be4f3dac</data>
  <data key="d4">unknown_source</data>
