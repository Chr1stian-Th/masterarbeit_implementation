<node id="Data Processor">
  <data key="d0">Data Processor</data>
  <data key="d1">organization</data>
  <data key="d2">A Data Processor is an individual or entity that processes personal data on behalf of the Data Controller.</data>
  <data key="d3">chunk-3fa893844a2197c46302e74437f2bbef</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018987</data>
