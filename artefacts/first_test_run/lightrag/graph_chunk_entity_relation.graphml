<node id="International Humanitarian Law">
  <data key="d0">International Humanitarian Law</data>
  <data key="d1">concept</data>
  <data key="d2">International humanitarian law governs the conduct of armed conflict and seeks to protect individuals who are not participating in hostilities.</data>
  <data key="d3">chunk-7071cdf0dedffd1eaf46713ebddb9b1e</data>
  <data key="d4">unknown_source</data>
