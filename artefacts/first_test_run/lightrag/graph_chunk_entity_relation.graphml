<node id="Data Subject Rights">
  <data key="d0">Data Subject Rights</data>
  <data key="d1">concept</data>
  <data key="d2">Data Subject Rights encompass legal protections afforded to individuals regarding their personal data, including access, correction, and deletion rights.</data>
  <data key="d3">chunk-5ab41d6ec0d1446be5ba58c1ab5b423c</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018991</data>
  <data key="d6"></data>
</node>
<node id="Legal Instrument">
  <data key="d0">Legal Instrument</data>
  <data key="d1">concept</data>
  <data key="d2">A Legal Instrument refers to enforceable documents or agreements that regulate the processing and transfer of personal data.</data>
  <data key="d3">chunk-5ab41d6ec0d1446be5ba58c1ab5b423c</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018991</data>
  <data key="d6"></data>
</node>
<node id="Article 1">
  <data key="d0">Article 1</data>
  <data key="d1">concept</data>
  <data key="d2">Article 1 outlines the subject-matter and objectives of the Regulation related to personal data protection.</data>
  <data key="d3">chunk-4c1a7de4ca41da4fd41e3254a6460114</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018991</data>
  <data key="d6"></data>
</node>
<node id="Article 2">
  <data key="d0">Article 2</data>
  <data key="d1">concept</data>
  <data key="d2">Article 2 defines the material scope of the Regulation regarding the processing of personal data by automated and non-automated means.&lt;SEP&gt;Article 2 specifies the scope of the Regulation, detailing its applicability to various providers, deployers, and third parties involved with AI systems.</data>
  <data key="d3">chunk-4c1a7de4ca41da4fd41e3254a6460114&lt;SEP&gt;chunk-55fa705f95ec5acec79f8b691041b65c</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019223</data>
  <data key="d6"></data>
</node>
<node id="Article 3">
  <data key="d0">Article 3</data>
  <data key="d1">document</data>
  <data key="d2">Article 3 describes the territorial application of the Regulation to controllers and processors involved in personal data processing.&lt;SEP&gt;Article 3 defines key concepts related to AI systems, including what constitutes a 'product presenting a risk'.</data>
  <data key="d3">chunk-4c1a7de4ca41da4fd41e3254a6460114&lt;SEP&gt;chunk-088a4c3c3c775d33baa63868a127c869</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019192</data>
  <data key="d6"></data>
</node>
<node id="Article 4">
  <data key="d0">Article 4</data>
  <data key="d1">content</data>
  <data key="d2">Article 4 offers definitions essential for understanding the Regulation, including terms like 'personal data' and 'processing'.&lt;SEP&gt;Article 4 outlines the requirements and responsibilities related to AI Literacy for providers and deployers of AI systems.</data>
  <data key="d3">chunk-4c1a7de4ca41da4fd41e3254a6460114&lt;SEP&gt;chunk-6f379f07f844b3112cd145a56e02874b</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019176</data>
  <data key="d6"></data>
</node>
<node id="Competent Courts">
  <data key="d0">Competent Courts</data>
  <data key="d1">organization</data>
  <data key="d2">Competent courts are legal authorities where data subjects can lodge complaints regarding breaches of their rights related to personal data processing.</data>
  <data key="d3">chunk-c22927198decad5ee173ab2f05d62983</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018991</data>
  <data key="d6"></data>
</node>
<node id="Article 37">
  <data key="d0">Article 37</data>
  <data key="d1">content</data>
  <data key="d2">Article 37 outlines the conditions for appointing a data protection officer within an organization.</data>
  <data key="d3">chunk-c22927198decad5ee173ab2f05d62983</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018991</data>
  <data key="d6"></data>
</node>
<node id="International Agreement">
  <data key="d0">International Agreement</data>
  <data key="d1">concept</data>
  <data key="d2">An international agreement is a treaty or formal accord between countries, which may govern the transfer of personal data.</data>
  <data key="d3">chunk-c22927198decad5ee173ab2f05d62983</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018991</data>
  <data key="d6"></data>
</node>
<node id="Mutual Legal Assistance Treaty">
  <data key="d0">Mutual Legal Assistance Treaty</data>
  <data key="d1">concept</data>
  <data key="d2">A mutual legal assistance treaty is an international agreement to facilitate cooperation in legal matters between countries, including data protection issues.</data>
  <data key="d3">chunk-c22927198decad5ee173ab2f05d62983</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018991</data>
  <data key="d6"></data>
</node>
<node id="Identifier">
  <data key="d0">Identifier</data>
  <data key="d1">concept</data>
  <data key="d2">An identifier refers to a name, identification number, location data, or online identifier related to a natural person's identity.</data>
  <data key="d3">chunk-7e5e9be572ec001588771fa74ce45258</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018991</data>
  <data key="d6"></data>
</node>
<node id="Filing System">
  <data key="d0">Filing System</data>
  <data key="d1">concept</data>
  <data key="d2">A filing system is a structured set of personal data accessible according to specific criteria.</data>
  <data key="d3">chunk-7e5e9be572ec001588771fa74ce45258</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018991</data>
  <data key="d6"></data>
</node>
<node id="Recipient">
  <data key="d0">Recipient</data>
  <data key="d1">concept</data>
  <data key="d2">A recipient is an entity to which personal data are disclosed, including public authorities under certain conditions.</data>
  <data key="d3">chunk-7e5e9be572ec001588771fa74ce45258</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018991</data>
  <data key="d6"></data>
</node>
<node id="Article 45">
  <data key="d0">Article 45</data>
  <data key="d1">concept</data>
  <data key="d2">Article 45 outlines conditions for transferring personal data to third countries or international organizations in the absence of an adequacy decision.</data>
  <data key="d3">chunk-5b3266fc2be81fd61dcffc1afc41700b</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018991</data>
  <data key="d6"></data>
</node>
<node id="Legitimate Interest">
  <data key="d0">Legitimate Interest</data>
  <data key="d1">concept</data>
  <data key="d2">Legitimate Interest is a condition under which personal data can be legally transferred if it aligns with compelling interests pursued by the Controller.</data>
  <data key="d3">chunk-5b3266fc2be81fd61dcffc1afc41700b</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018991</data>
  <data key="d6"></data>
</node>
<node id="Data Protection Policies">
  <data key="d0">Data Protection Policies</data>
  <data key="d1">method</data>
  <data key="d2">Data protection policies are measures implemented by the controller to safeguard personal data during processing activities.</data>
  <data key="d3">chunk-6ad40e7a844b107cf5d24e2adca46bdb</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018991</data>
  <data key="d6"></data>
</node>
<node id="Approved Codes of Conduct">
  <data key="d0">Approved Codes of Conduct</data>
  <data key="d1">method</data>
  <data key="d2">Approved codes of conduct refer to established guidelines that help demonstrate compliance with data protection obligations.</data>
  <data key="d3">chunk-6ad40e7a844b107cf5d24e2adca46bdb</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018991</data>
  <data key="d6"></data>
</node>
<node id="Joint Controllers">
  <data key="d0">Joint Controllers</data>
  <data key="d1">concept</data>
  <data key="d2">Joint controllers are entities that jointly determine the purposes and means of processing personal data, sharing responsibility for compliance.</data>
  <data key="d3">chunk-6ad40e7a844b107cf5d24e2adca46bdb</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018991</data>
  <data key="d6"></data>
</node>
<node id="Article 25">
  <data key="d0">Article 25</data>
  <data key="d1">concept</data>
  <data key="d2">Article 25 outlines the principle of data protection by design and by default, emphasizing the need for appropriate measures.</data>
  <data key="d3">chunk-6ad40e7a844b107cf5d24e2adca46bdb</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018991</data>
  <data key="d6"></data>
</node>
<node id="Article 26">
  <data key="d0">Article 26</data>
  <data key="d1">concept</data>
  <data key="d2">Article 26 discusses the framework for joint controllers and their responsibilities regarding data processing.&lt;SEP&gt;Article 26 establishes obligations for deployers, specifying their duties under regulations.&lt;SEP&gt;Article 26 specifies the obligations of deployers within the context of EU legislation.</data>
  <data key="d3">chunk-6ad40e7a844b107cf5d24e2adca46bdb&lt;SEP&gt;chunk-7f5283f6c8ea50d5bcac79684f773610&lt;SEP&gt;chunk-b45385ec456bd2744fcc58cd02368fc0</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019202</data>
  <data key="d6"></data>
</node>
<node id="Article 27">
  <data key="d0">Article 27</data>
  <data key="d1">concept</data>
  <data key="d2">Article 27 details the requirements for representatives of controllers or processors not established in the Union.&lt;SEP&gt;Article 27 refers to regulations that govern the assessments necessary for compliance related to AI systems.</data>
  <data key="d3">chunk-6ad40e7a844b107cf5d24e2adca46bdb&lt;SEP&gt;chunk-81b13333cc1be55a8f31fdada74da057</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019216</data>
  <data key="d6"></data>
</node>
<node id="Cross-Border Processing">
  <data key="d0">Cross-Border Processing</data>
  <data key="d3">chunk-ca204399e5b95988e550678c5f4db7ee</data>
  <data key="d2">The lead supervisory authority oversees cross-border processing carried out by controllers or processors.</data>
  <data key="d1">UNKNOWN</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018996</data>
  <data key="d6"></data>
</node>
<node id="Other Supervisory Authorities">
  <data key="d0">Other Supervisory Authorities</data>
  <data key="d3">chunk-ca204399e5b95988e550678c5f4db7ee</data>
  <data key="d2">The lead supervisory authority coordinates with other supervisory authorities to maintain consistent application of data protection regulations.</data>
  <data key="d1">UNKNOWN</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018997</data>
  <data key="d6"></data>
</node>
<node id="Competent National Courts">
  <data key="d0">Competent National Courts</data>
  <data key="d3">chunk-87f4c2229943d3f8e84a9941f117b8b1</data>
  <data key="d2">In Denmark, competent national courts are responsible for imposing fines as criminal penalties.</data>
  <data key="d1">UNKNOWN</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019017</data>
  <data key="d6"></data>
</node>
<node id="Article 71">
  <data key="d0">Article 71</data>
  <data key="d3">chunk-9e09a4cc6243398f5e32d65a6312bd87&lt;SEP&gt;chunk-38cdce9b64b40ba40d6acb529d375787</data>
  <data key="d2">The Board is responsible for drawing up the annual report as stipulated in Article 71 regarding data protection.&lt;SEP&gt;Article 71 refers to a specific article in the regulation outlining necessary checks based on EU database information.</data>
  <data key="d1">concept</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019195</data>
  <data key="d6"></data>
</node>
<node id="Article 72">
  <data key="d0">Article 72</data>
  <data key="d3">chunk-9e09a4cc6243398f5e32d65a6312bd87&lt;SEP&gt;chunk-cb73a01a1d9b0ba7ee87eb6d896fbea4&lt;SEP&gt;chunk-5a13415ed2c222ba72d78fdab855a6ca&lt;SEP&gt;chunk-d08b2a930ede07e77c7cc4f29016fc57</data>
  <data key="d2">Article 72 defines how The Board takes decisions and adopts its own rules of procedure.&lt;SEP&gt;Article 72 pertains to post-market monitoring of high-risk AI systems and tracking their compliance and operational integrity.&lt;SEP&gt;Article 72 refers to a specific provision that outlines obligations for providers and deployers regarding the notification of risks associated with high-risk AI systems.&lt;SEP&gt;Article 72 pertains to post-market monitoring of AI systems, ensuring ongoing compliance with standards.</data>
  <data key="d1">concept</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019198</data>
  <data key="d6"></data>
</node>
<node id="Decision of the Board">
  <data key="d0">Decision of the Board</data>
  <data key="d3">chunk-af27fd67de6b968672bf93dbf11392ac</data>
  <data key="d2">Individuals can bring an action for annulment against decisions made by the Board within a specified timeframe.</data>
  <data key="d1">UNKNOWN</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019033</data>
  <data key="d6"></data>
</node>
<node id="Controller or Processor">
  <data key="d0">Controller or Processor</data>
  <data key="d3">chunk-5f500418ca711a20a360004da8c1f5ff</data>
  <data key="d2">Controllers or processors must comply with the Regulation and may be liable for damages resulting from improper processing.</data>
  <data key="d1">UNKNOWN</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019034</data>
  <data key="d6"></data>
</node>
<node id="Controller/Processor">
  <data key="d0">Controller/Processor</data>
  <data key="d3">chunk-b1184185c4bc8012fe969516fa45f07b</data>
  <data key="d2">Main Establishment serves as the central administrative point for making key decisions about personal data processing for controllers and processors.</data>
  <data key="d1">UNKNOWN</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019050</data>
  <data key="d6"></data>
</node>
<node id="Economic Activity">
  <data key="d0">Economic Activity</data>
  <data key="d3">chunk-b1184185c4bc8012fe969516fa45f07b</data>
  <data key="d2">Enterprise signifies any entity participating in economic activities, regardless of its legal structure.</data>
  <data key="d1">UNKNOWN</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019051</data>
  <data key="d6"></data>
</node>
<node id="Draft Decision">
  <data key="d0">Draft Decision</data>
  <data key="d3">chunk-b1184185c4bc8012fe969516fa45f07b</data>
  <data key="d2">Relevant and Reasoned Objection addresses potential infringements and regulatory compliance issues regarding draft decisions affecting personal data processing.</data>
  <data key="d1">UNKNOWN</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019051</data>
  <data key="d6"></data>
</node>
<node id="Article 93">
  <data key="d0">Article 93</data>
  <data key="d3">chunk-5ab41d6ec0d1446be5ba58c1ab5b423c&lt;SEP&gt;chunk-f137cf6069f0720a443c5b5abd0fe3ea&lt;SEP&gt;chunk-382f1c7a3c02bab4bf3bee2d03cc7e1f</data>
  <data key="d2">Standard Data Protection Clauses must be adopted in accordance with Article 93's examination procedure to ensure compliance with data protection laws.&lt;SEP&gt;Article 93 grants the Commission the power to request measures from providers of general-purpose AI models.&lt;SEP&gt;Article 93 relates to specific measures requested for compliance and evaluation of general-purpose AI models.</data>
  <data key="d1">content</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019200</data>
  <data key="d6"></data>
</node>
<node id="Input Data">
  <data key="d0">Input Data</data>
  <data key="d1">concept</data>
  <data key="d2">Input Data refers to data provided to or directly acquired by an AI system, which is essential for producing outputs.&lt;SEP&gt;Input data is provided to or acquired by an AI system for producing outputs.</data>
  <data key="d3">chunk-aebf35e601756ab37e5d744110a4c050&lt;SEP&gt;chunk-5e14a05a776d89b0f172b0c5789b0936</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019165</data>
  <data key="d6"></data>
</node>
<node id="Biometric Identification">
  <data key="d0">Biometric Identification</data>
  <data key="d1">concept</data>
  <data key="d2">Biometric identification is characterized as the automated recognition of human features for establishing identity by comparing individual biometric data to stored data.&lt;SEP&gt;Biometric identification refers to the use of biological characteristics for identifying individuals, which may lead to biased results and discriminatory effects.&lt;SEP&gt;Biometric Identification is the automated recognition of human features for identity verification through comparison of biometric data.</data>
  <data key="d3">chunk-aebf35e601756ab37e5d744110a4c050&lt;SEP&gt;chunk-22dcb6c71a1828d1166aad9d5a7cac19&lt;SEP&gt;chunk-ab5bd61fedb2857e3db189c5f7bb8f94</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019165</data>
  <data key="d6"></data>
</node>
<node id="Biometric Verification">
  <data key="d0">Biometric Verification</data>
  <data key="d1">concept</data>
  <data key="d2">Biometric Verification is the one-to-one confirmation of identity by comparing an individual's biometric data with previously stored data.</data>
  <data key="d3">chunk-aebf35e601756ab37e5d744110a4c050</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019165</data>
  <data key="d6"></data>
</node>
<node id="Sensitive Operational Data">
  <data key="d0">Sensitive Operational Data</data>
  <data key="d1">concept</data>
  <data key="d2">Sensitive Operational Data relates to information important for the prevention or investigation of criminal offenses.</data>
  <data key="d3">chunk-aebf35e601756ab37e5d744110a4c050</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019165</data>
  <data key="d6"></data>
</node>
<node id="Emotion Recognition System">
  <data key="d0">Emotion Recognition System</data>
  <data key="d1">concept</data>
  <data key="d2">The emotion recognition system is an AI system designed to identify or infer the emotions or intentions of individuals based on biometric data.&lt;SEP&gt;An Emotion Recognition System is an AI system designed to identify or infer emotions of natural persons based on biometric data.&lt;SEP&gt;Emotion recognition systems are AI technologies designed to analyze and interpret emotional expressions but require transparency regarding their operation.</data>
  <data key="d3">chunk-aebf35e601756ab37e5d744110a4c050&lt;SEP&gt;chunk-6d043d4edae3c59146709349b2875a92&lt;SEP&gt;chunk-df495629e0a16630b58b47ba83c27efa</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019165</data>
  <data key="d6"></data>
</node>
<node id="Biometric Categorisation System">
  <data key="d0">Biometric Categorisation System</data>
  <data key="d1">concept</data>
  <data key="d2">A Biometric Categorisation System is an AI system that assigns natural persons to specific categories using their biometric data.&lt;SEP&gt;Biometric categorisation systems use biometric data to classify individuals based on physical characteristics and have transparency obligations when deployed.</data>
  <data key="d3">chunk-aebf35e601756ab37e5d744110a4c050&lt;SEP&gt;chunk-6d043d4edae3c59146709349b2875a92</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019165</data>
  <data key="d6"></data>
</node>
<node id="Remote Biometric Identification System">
  <data key="d0">Remote Biometric Identification System</data>
  <data key="d1">concept</data>
  <data key="d2">The remote biometric identification system is an AI system for identifying individuals without their active involvement, often using biometric data comparisons.&lt;SEP&gt;A Remote Biometric Identification System identifies natural persons at a distance using their biometric data without their involvement.</data>
  <data key="d3">chunk-aebf35e601756ab37e5d744110a4c050&lt;SEP&gt;chunk-df495629e0a16630b58b47ba83c27efa</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019166</data>
  <data key="d6"></data>
</node>
<node id="Real-Time Remote Biometric Identification System">
  <data key="d0">Real-Time Remote Biometric Identification System</data>
  <data key="d1">concept</data>
  <data key="d2">A Real-Time Remote Biometric Identification System identifies individuals without significant delay during biometric data capture.&lt;SEP&gt;The Real-Time Remote Biometric Identification System is a technology used for identifying individuals in publicly accessible spaces for law enforcement purposes.</data>
  <data key="d3">chunk-aebf35e601756ab37e5d744110a4c050&lt;SEP&gt;chunk-f40cde20fc8948de8e853c9a34187f56</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019166</data>
  <data key="d6"></data>
</node>
<node id="Post-Remote Biometric Identification System">
  <data key="d0">Post-Remote Biometric Identification System</data>
  <data key="d1">concept</data>
  <data key="d2">A Post-Remote Biometric Identification System refers to remote identification processes that do not qualify as real-time identification.&lt;SEP&gt;A post-remote biometric identification system is a technology used for identifying individuals based on biometric data after an incident occurs.&lt;SEP&gt;The Post-Remote Biometric Identification System is an AI system intended for law enforcement that operates without direct ties to specific criminal cases or individuals.</data>
  <data key="d3">chunk-aebf35e601756ab37e5d744110a4c050&lt;SEP&gt;chunk-5a13415ed2c222ba72d78fdab855a6ca&lt;SEP&gt;chunk-880ccb1f68ffcae0925e238408590ede</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019166</data>
  <data key="d6"></data>
</node>
<node id="Publicly Accessible Space">
  <data key="d0">Publicly Accessible Space</data>
  <data key="d1">concept</data>
  <data key="d2">Publicly Accessible Space refers to any physical location that is available for entry by an undetermined number of natural persons, regardless of ownership or intended activity.&lt;SEP&gt;Publicly Accessible Space denotes any physical area that is open to individuals, regardless of specific access conditions.</data>
  <data key="d3">chunk-aebf35e601756ab37e5d744110a4c050&lt;SEP&gt;chunk-97987bc5b95dc5a6f6ebc189b5a394a1</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019166</data>
  <data key="d6"></data>
</node>
<node id="Law Enforcement Authority">
  <data key="d0">Law Enforcement Authority</data>
  <data key="d1">concept</data>
  <data key="d2">Law Enforcement Authority includes public or designated bodies responsible for managing criminal investigations and maintaining public security.</data>
  <data key="d3">chunk-aebf35e601756ab37e5d744110a4c050</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019166</data>
  <data key="d6"></data>
</node>
<node id="Law Enforcement">
  <data key="d0">Law Enforcement</data>
  <data key="d1">concept</data>
  <data key="d2">Law enforcement pertains to the system and activities involved in upholding laws and maintaining public order.&lt;SEP&gt;Law Enforcement encompasses activities undertaken by authorities to prevent and address criminal conduct.&lt;SEP&gt;Law enforcement refers to governmental agencies' role in maintaining public order, preventing crime, and enforcing laws, which can involve the use of biometric identification systems.&lt;SEP&gt;Law enforcement refers to the system and agencies responsible for maintaining public order and applying the law.</data>
  <data key="d3">chunk-aebf35e601756ab37e5d744110a4c050&lt;SEP&gt;chunk-62c64f05f2da893351ea92b9eac1c889&lt;SEP&gt;chunk-f40cde20fc8948de8e853c9a34187f56&lt;SEP&gt;chunk-6b5a506beb14df3337a120faddb2f0b6&lt;SEP&gt;chunk-880ccb1f68ffcae0925e238408590ede</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019166</data>
  <data key="d6"></data>
</node>
<node id="National Competent Authority">
  <data key="d0">National Competent Authority</data>
  <data key="d1">organization</data>
  <data key="d2">National Competent Authority refers to entities responsible for notifying or overseeing market surveillance activities regarding AI systems.&lt;SEP&gt;National competent authority is defined as a notifying authority or a market surveillance authority responsible for overseeing AI systems.&lt;SEP&gt;The National Competent Authority is designated by member states to manage specific responsibilities related to market surveillance and serious incident notifications.</data>
  <data key="d3">chunk-aebf35e601756ab37e5d744110a4c050&lt;SEP&gt;chunk-f4b86ca29202de00c1292db00c1efa4b&lt;SEP&gt;chunk-80a99ad850f0546ea9da41c8d764b154</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019166</data>
  <data key="d6"></data>
</node>
<node id="EU Database for High-Risk AI Systems">
  <data key="d0">EU Database for High-Risk AI Systems</data>
  <data key="d1">data</data>
  <data key="d2">The EU database contains information on high-risk AI systems to ensure compliance with regulations and is maintained by the Commission.</data>
  <data key="d3">chunk-663826fe1821a9ef057cd84da3b741a8</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019166</data>
  <data key="d6"></data>
</node>
<node id="Annex VIII">
  <data key="d0">Annex VIII</data>
  <data key="d1">data</data>
  <data key="d2">Annex VIII provides detailed information that must be included when registering high-risk AI systems in the EU database.&lt;SEP&gt;Annex VIII outlines the specific sections listing the data to be entered into the EU database for high-risk AI systems.</data>
  <data key="d3">chunk-663826fe1821a9ef057cd84da3b741a8&lt;SEP&gt;chunk-6fe225f6b6c5b43aceb1fd1109bf8e4f</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019167</data>
  <data key="d6"></data>
</node>
<node id="AI Office">
  <data key="d0">AI Office</data>
  <data key="d1">organization</data>
  <data key="d2">The AI Office is an entity established by the European Commission with a multifaceted role in overseeing compliance and governance of general-purpose Artificial Intelligence (AI) systems and models within the European Union. This office is responsible for ensuring that providers of general-purpose AI models adhere to obligations related to copyright law and other regulatory requirements, particularly those concerning systemic risks.

The AI Office engages actively with the scientific community and industry stakeholders to facilitate the responsible development and regulation of AI technologies. It monitors compliance with regulations, oversees the implementation of these regulations, and supports national competent authorities in enforcing AI compliance measures. This involvement includes assisting in the establishment of AI regulatory sandboxes, which are designed to foster innovation while maintaining oversight and safety.

Moreover, the AI Office plays a significant role in the classification and evaluation of AI models, promoting the development of codes of practice aimed at both quality assurance and issues concerning the detection and labeling of artificially generated or manipulated content. It is also responsible for the formulation of templates for compliance questionnaires and may recommend voluntary model terms for high-risk AI system contracts.

In addition to its supervisory functions, the AI Office coordinates joint investigations related to AI systems and compliance activities, striving to cultivate expertise and capabilities in the AI sector. Overall, it acts as a governing body tasked with important regulatory responsibilities, contributing to the safe and effective deployment of AI technologies in alignment with EU regulations.</data>
  <data key="d3">chunk-aebf35e601756ab37e5d744110a4c050&lt;SEP&gt;chunk-a242b3e1d633e7e955057a9b078f32d2&lt;SEP&gt;chunk-e5af0747da2a9f2783a1bde010a13814&lt;SEP&gt;chunk-e318b5cf27cebec499fc2e251461775a&lt;SEP&gt;chunk-6651a485fa4747217fdc9be856c3bf9d&lt;SEP&gt;chunk-f137cf6069f0720a443c5b5abd0fe3ea&lt;SEP&gt;chunk-474ee56c196aef9638f343ef09589bca&lt;SEP&gt;chunk-fe99ac2ad30ad5f2f6c6c5e2e23456e9&lt;SEP&gt;chunk-d5f6ef3b354bb0dbf8af7b2c108fd236&lt;SEP&gt;chunk-e128fa4453175248aac2b8414bc17643&lt;SEP&gt;chunk-0a8f57272764fbaa96a8c14389c0661d&lt;SEP&gt;chunk-d97d0e266280dff1c105fac7dc08fc5d&lt;SEP&gt;chunk-ed27aea701ddc7f366ea5adbe8a4b8e8&lt;SEP&gt;chunk-6d043d4edae3c59146709349b2875a92&lt;SEP&gt;chunk-546a0f6bb154d36417ac57e86137b45d&lt;SEP&gt;chunk-15ddf6f50e7dd1750489a4999454bcdf&lt;SEP&gt;chunk-13766dce116c63c31fc5d746b27279fc&lt;SEP&gt;chunk-df0cf5bee4370453cb38606bad89b764&lt;SEP&gt;chunk-5ba035757525dfa257fa2b97fdbd40b2&lt;SEP&gt;chunk-f743aee05d8e1afc03000436802a1ad2&lt;SEP&gt;chunk-22207e9a20c55a3749a58440b8aab4fd&lt;SEP&gt;chunk-ccdea28ee93cb8cfdf2099776ddcb591&lt;SEP&gt;chunk-3b1941526d498e207caabd2fb04f938f&lt;SEP&gt;chunk-4996cfa66f0668d565cd83bbe46dd21a&lt;SEP&gt;chunk-77f7e4da7918161a180fb26c5a1704ff&lt;SEP&gt;chunk-413f3509ccce7d84f0a2044eb12be69f&lt;SEP&gt;chunk-d5a5973b039f9a9af3e3e9d93b392c66</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019170</data>
  <data key="d6"></data>
</node>
<node id="Commission Decision">
  <data key="d0">Commission Decision</data>
  <data key="d1">event</data>
  <data key="d2">The Commission Decision of 24 January 2024 pertains to the governance and regulation of AI systems in the European Union.</data>
  <data key="d3">chunk-f4b86ca29202de00c1292db00c1efa4b</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019170</data>
