  <data key="d0">Regulation (EU) No 536/2014</data>
  <data key="d1">concept</data>
  <data key="d2">Regulation (EU) No 536/2014 governs the conduct of clinical trials on medicinal products for human use in the European Union.</data>
  <data key="d3">chunk-87ae75b9888750c7d94cfda6be4f3dac</data>
