  <data key="d13"></data>
</edge>
<edge source="Natural Persons" target="Human Oversight">
  <data key="d7">1.0</data>
  <data key="d8">Natural persons hold oversight responsibilities aimed at interpreting the outputs of high-risk AI systems.</data>
  <data key="d9">oversight role,responsibility</data>
  <data key="d10">chunk-7c2fbe724dee488ea4e437995307241f</data>
