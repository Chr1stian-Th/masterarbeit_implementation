</node>
<node id="Political Parties">
  <data key="d0">Political Parties</data>
  <data key="d1">organization</data>
  <data key="d2">Political parties are organizations that may collect personal data on political opinions during electoral activities for reasons of public interest.</data>
  <data key="d3">chunk-97d77d4c79204175483320a1c612b93b</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018986</data>
  <data key="d6"></data>
</node>
<node id="Employers">
  <data key="d0">Employers</data>
  <data key="d1">organization</data>
  <data key="d2">Employers are entities that, as third parties, should not process personal data collected for other purposes without proper consent.</data>
  <data key="d3">chunk-97d77d4c79204175483320a1c612b93b</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018986</data>
  <data key="d6"></data>
</node>
<node id="Insurance Companies">
  <data key="d0">Insurance Companies</data>
  <data key="d1">organization</data>
  <data key="d2">Insurance companies are entities that are mentioned as potential third parties not permitted to process personal data gathered under public interest.</data>
  <data key="d3">chunk-97d77d4c79204175483320a1c612b93b</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018986</data>
  <data key="d6"></data>
</node>
<node id="Banking Companies">
  <data key="d0">Banking Companies</data>
  <data key="d1">organization</data>
  <data key="d2">Banking companies are mentioned as third parties that should not process personal data collected for reasons of public interest without consent.</data>
  <data key="d3">chunk-97d77d4c79204175483320a1c612b93b</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018986</data>
  <data key="d6"></data>
</node>
<node id="Parental Responsibility Holder">
  <data key="d0">Parental Responsibility Holder</data>
  <data key="d1">person</data>
  <data key="d2">The holder of parental responsibility is a person who has legal rights and duties regarding the care of a child, whose consent is generally required for processing children's data.&lt;SEP&gt;The holder of parental responsibility is an individual who can give or authorize consent for processing personal data on behalf of a child.</data>
  <data key="d3">chunk-35884c5ef57faf321ff9fce99bd2d970&lt;SEP&gt;chunk-c09ea8bbba955df15eafbe1da5facb38</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018986</data>
  <data key="d6"></data>
</node>
<node id="Legitimate Basis">
  <data key="d0">Legitimate Basis</data>
  <data key="d1">concept</data>
  <data key="d2">Legitimate basis refers to lawful justifications under which personal data may be processed, as outlined by regulations.</data>
  <data key="d3">chunk-35884c5ef57faf321ff9fce99bd2d970</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018986</data>
  <data key="d6"></data>
</node>
<node id="Risks">
  <data key="d0">Risks</data>
  <data key="d1">concept</data>
  <data key="d2">Risks involve potential negative outcomes related to the processing of personal data that individuals should be aware of.</data>
  <data key="d3">chunk-35884c5ef57faf321ff9fce99bd2d970</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018986</data>
  <data key="d6"></data>
</node>
<node id="Safeguards">
  <data key="d0">Safeguards</data>
  <data key="d1">concept</data>
  <data key="d2">Safeguards are measures implemented to protect personal data from unauthorized access and ensure security.</data>
  <data key="d3">chunk-35884c5ef57faf321ff9fce99bd2d970</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018987</data>
  <data key="d6"></data>
</node>
<node id="Pseudonymisation">
  <data key="d0">Pseudonymisation</data>
  <data key="d1">method</data>
  <data key="d2">Pseudonymisation is a data protection technique that involves replacing private identifiers with fictitious names or identifiers.&lt;SEP&gt;Pseudonymisation is a data processing method used to protect personal data by replacing identifying fields with artificial identifiers.&lt;SEP&gt;Pseudonymisation is the processing of personal data so that it cannot be attributed to a specific individual without additional information.</data>
  <data key="d3">chunk-499a505625518b0e48c48965f5a70336&lt;SEP&gt;chunk-a0ea41c30759ecd048ab40483ec1605b&lt;SEP&gt;chunk-7e5e9be572ec001588771fa74ce45258</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018987</data>
  <data key="d6"></data>
</node>
<node id="Anonymous Information">
  <data key="d0">Anonymous Information</data>
  <data key="d1">concept</data>
  <data key="d2">Anonymous information is data that does not relate to an identified or identifiable natural person and is not subject to data protection regulations.</data>
  <data key="d3">chunk-499a505625518b0e48c48965f5a70336</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018987</data>
  <data key="d6"></data>
</node>
<node id="Health Purposes">
  <data key="d0">Health Purposes</data>
  <data key="d1">concept</data>
  <data key="d2">Health purposes involve identifying a natural person for health-related reasons, including medical and physiological information.</data>
  <data key="d3">chunk-8e3626adc7cf865bec83f6479c1e08cb</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018987</data>
  <data key="d6"></data>
</node>
<node id="Body Part">
  <data key="d0">Body Part</data>
  <data key="d1">naturalobject</data>
  <data key="d2">A body part is a physical part of a natural person that may be tested or examined for health assessments.</data>
  <data key="d3">chunk-8e3626adc7cf865bec83f6479c1e08cb</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018987</data>
  <data key="d6"></data>
</node>
<node id="Biological Samples">
  <data key="d0">Biological Samples</data>
  <data key="d1">naturalobject</data>
  <data key="d2">Biological samples are specimens taken from a natural person that can provide genetic and health-related information.&lt;SEP&gt;Biological samples are samples taken from living organisms used for analysis, including DNA and RNA, to identify genetic data.</data>
  <data key="d3">chunk-8e3626adc7cf865bec83f6479c1e08cb&lt;SEP&gt;chunk-f4dfe3f1190ff8cf7dc9f62b85bed40a</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018987</data>
  <data key="d6"></data>
</node>
<node id="Disease">
  <data key="d0">Disease</data>
  <data key="d1">concept</data>
  <data key="d2">Disease refers to any abnormal condition affecting a natural person's body or mind, which may require medical attention.</data>
  <data key="d3">chunk-8e3626adc7cf865bec83f6479c1e08cb</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018987</data>
  <data key="d6"></data>
</node>
<node id="Disability">
  <data key="d0">Disability</data>
  <data key="d1">concept</data>
  <data key="d2">Disability denotes a physical or mental condition that limits a natural person's movements, senses, or activities.</data>
  <data key="d3">chunk-8e3626adc7cf865bec83f6479c1e08cb</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018987</data>
  <data key="d6"></data>
</node>
<node id="Medical History">
  <data key="d0">Medical History</data>
  <data key="d1">concept</data>
  <data key="d2">Medical history encompasses all health-related information and past medical conditions of a natural person.</data>
  <data key="d3">chunk-8e3626adc7cf865bec83f6479c1e08cb</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018987</data>
