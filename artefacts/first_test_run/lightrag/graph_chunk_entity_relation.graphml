<node id="Copyright Exceptions">
  <data key="d0">Copyright Exceptions</data>
  <data key="d1">concept</data>
  <data key="d2">Copyright exceptions refer to specific provisions within copyright law allowing limited use of works without seeking permission from rightsholders under certain conditions.</data>
  <data key="d3">chunk-e128fa4453175248aac2b8414bc17643</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019210</data>
