  <data key="d0">Regulation (EU) No 1215/2012</data>
  <data key="d1">document</data>
  <data key="d2">Regulation (EU) No 1215/2012 concerns jurisdiction and the recognition and enforcement of judgments in civil and commercial matters.</data>
