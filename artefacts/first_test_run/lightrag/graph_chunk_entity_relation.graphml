  <data key="d0">Data Concerning Health</data>
  <data key="d1">concept</data>
  <data key="d2">Data Concerning Health includes personal data connected to an individual's physical or mental health, impacting health care service provision and revealing health status.</data>
  <data key="d3">chunk-b1184185c4bc8012fe969516fa45f07b</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018990</data>
