  <data key="d0">Environmental Protection</data>
  <data key="d1">concept</data>
  <data key="d2">Environmental protection involves measures to safeguard the quality of the environment and biodiversity, as well as combat climate change.</data>
  <data key="d3">chunk-1e0d95f75393cb87bb510dfcf3ba0ef5</data>
