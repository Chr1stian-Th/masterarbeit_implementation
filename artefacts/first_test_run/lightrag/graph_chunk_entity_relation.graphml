<node id="Notifying Authorities">
  <data key="d0">Notifying Authorities</data>
  <data key="d1">organization</data>
  <data key="d2">Notifying Authorities serve to inform relevant stakeholders about compliance and regulatory issues within the context of AI.&lt;SEP&gt;Notifying authorities are designated by Member States to oversee conformity assessment procedures and ensure compliance with regulations.</data>
  <data key="d3">chunk-fe99ac2ad30ad5f2f6c6c5e2e23456e9&lt;SEP&gt;chunk-df0cf5bee4370453cb38606bad89b764</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019209</data>
  <data key="d6"></data>
</node>
<node id="Conformity Assessment Bodies">
  <data key="d0">Conformity Assessment Bodies</data>
  <data key="d1">organization</data>
  <data key="d2">Conformity Assessment Bodies are organizations that apply for notification to notifying authorities and undergo assessments for compliance.&lt;SEP&gt;Conformity assessment bodies are organizations responsible for verifying compliance with regulatory standards, particularly in the context of high-risk AI systems from third countries.</data>
  <data key="d3">chunk-fe99ac2ad30ad5f2f6c6c5e2e23456e9&lt;SEP&gt;chunk-f0714fdb65a0577bc4493dcb81d0a915</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019209</data>
  <data key="d6"></data>
</node>
<node id="Providers of General-Purpose AI Models">
  <data key="d0">Providers of General-Purpose AI Models</data>
  <data key="d1">organization</data>
  <data key="d2">Providers of general-purpose AI models are organizations responsible for developing and supplying AI models for integration into various applications.&lt;SEP&gt;Providers of general-purpose AI models are specifically responsible for complying with obligations outlined in the Regulation regarding AI safety.</data>
  <data key="d3">chunk-bf9439294cd1ddefbd5a696360ace9e7&lt;SEP&gt;chunk-4996cfa66f0668d565cd83bbe46dd21a&lt;SEP&gt;chunk-d97d0e266280dff1c105fac7dc08fc5d&lt;SEP&gt;chunk-ed27aea701ddc7f366ea5adbe8a4b8e8</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019209</data>
  <data key="d6"></data>
</node>
<node id="Downstream Providers">
  <data key="d0">Downstream Providers</data>
  <data key="d1">organization</data>
  <data key="d2">Downstream providers are entities that utilize general-purpose AI models in their products and require understanding of the models' capabilities.</data>
  <data key="d3">chunk-bf9439294cd1ddefbd5a696360ace9e7</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019209</data>
  <data key="d6"></data>
</node>
<node id="Free and Open-Source AI Components">
  <data key="d0">Free and Open-Source AI Components</data>
  <data key="d1">concept</data>
  <data key="d2">Free and open-source AI components include software and data that can be accessed, modified, and redistributed under certain licensing conditions.</data>
  <data key="d3">chunk-bf9439294cd1ddefbd5a696360ace9e7</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019209</data>
  <data key="d6"></data>
</node>
<node id="Union Economy">
  <data key="d0">Union Economy</data>
  <data key="d1">location</data>
  <data key="d2">The Union economy refers to the economic system of the European Union, which is impacted by advancements in AI and technology.</data>
  <data key="d3">chunk-bf9439294cd1ddefbd5a696360ace9e7</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019209</data>
  <data key="d6"></data>
