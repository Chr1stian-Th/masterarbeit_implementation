  <data key="d13"></data>
</edge>
<edge source="Data Subject" target="Article 16">
  <data key="d7">1.0</data>
  <data key="d8">The Data Subject has the right to request rectification of inaccurate personal data under Article 16.</data>
  <data key="d9">personal data accuracy,rectification rights</data>
  <data key="d10">chunk-2016931a6e14615018d3d7f8304b6a1e</data>
  <data key="d11">unknown_source</data>
