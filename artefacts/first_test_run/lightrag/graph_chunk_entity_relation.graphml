  <data key="d0">Articles 57</data>
  <data key="d1">concept</data>
  <data key="d2">Article 57 addresses the functioning of AI regulatory sandboxes within the context of the Regulation.</data>
  <data key="d3">chunk-413f3509ccce7d84f0a2044eb12be69f</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019223</data>
  <data key="d6"></data>
</node>
<node id="Articles 59">
  <data key="d0">Articles 59</data>
  <data key="d1">concept</data>
  <data key="d2">Article 59 is concerned with specific aspects of testing AI systems in relation to the Regulation.</data>
  <data key="d3">chunk-413f3509ccce7d84f0a2044eb12be69f</data>
