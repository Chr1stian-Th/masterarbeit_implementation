  <data key="d6"></data>
</node>
<node id="Floating-Point Operation">
  <data key="d0">Floating-Point Operation</data>
  <data key="d1">concept</data>
  <data key="d2">A Floating-Point Operation is a mathematical operation involving floating-point numbers used in computing.</data>
  <data key="d3">chunk-6f379f07f844b3112cd145a56e02874b</data>
  <data key="d4">unknown_source</data>
