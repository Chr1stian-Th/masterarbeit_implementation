  <data key="d13"></data>
</edge>
<edge source="Data Subject" target="Article 17">
  <data key="d7">1.0</data>
  <data key="d8">The Data Subject can request erasure of Personal Data if it has been unlawfully processed, as specified in Article 17.</data>
