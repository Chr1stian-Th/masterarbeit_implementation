  <data key="d1">content</data>
  <data key="d2">Directive 2014/32/EU applies to the harmonization of laws concerning measuring instruments available on the European market.</data>
  <data key="d3">chunk-46bc64e87ac07d3576c10a8dd9d66d9e</data>
