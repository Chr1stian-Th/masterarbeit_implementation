<node id="Reinforcement Learning">
  <data key="d0">Reinforcement Learning</data>
  <data key="d1">method</data>
  <data key="d2">Reinforcement learning is a method in which AI models learn to make decisions based on rewards received from their actions.</data>
  <data key="d3">chunk-93ef23a1d24ffc516addd681974bac32</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019208</data>
  <data key="d6"></data>
</node>
<node id="Parameters">
  <data key="d0">Parameters</data>
  <data key="d1">concept</data>
  <data key="d2">Parameters refer to numerical factors in AI models that determine their behavior and performance.</data>
  <data key="d3">chunk-93ef23a1d24ffc516addd681974bac32</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019208</data>
  <data key="d6"></data>
</node>
<node id="Annex X">
  <data key="d0">Annex X</data>
  <data key="d1">concept</data>
  <data key="d2">Annex X lists legal acts that establish large-scale IT systems and outlines the compliance requirements for AI systems placed on the market or put into service.</data>
  <data key="d3">chunk-b084b4b20e358aaf88a17e35cc6da65d</data>
