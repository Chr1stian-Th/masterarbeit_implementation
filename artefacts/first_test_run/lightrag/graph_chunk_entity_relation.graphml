  <data key="d0">EU Union</data>
  <data key="d1">organization</data>
  <data key="d2">The EU Union is a political and economic union of member states that are subject to common institutional frameworks and regulations.</data>
  <data key="d3">chunk-97987bc5b95dc5a6f6ebc189b5a394a1</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019219</data>
