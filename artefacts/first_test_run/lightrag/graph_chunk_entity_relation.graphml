  <data key="d1">concept</data>
  <data key="d2">Article 108 refers to a section of the amendments made to Regulation (EU) 2018/1139.</data>
  <data key="d3">chunk-e0bb1522a7ffbcc317a23b095e16b092</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019208</data>
  <data key="d6"></data>
</node>
<node id="Article 109">
  <data key="d0">Article 109</data>
  <data key="d1">concept</data>
  <data key="d2">Article 109 refers to a section concerning amendments to Regulation (EU) 2019/2144.</data>
  <data key="d3">chunk-e0bb1522a7ffbcc317a23b095e16b092</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019208</data>
  <data key="d6"></data>
</node>
<node id="Deployer">
  <data key="d0">Deployer</data>
  <data key="d1">concept</data>
  <data key="d2">A deployer is responsible for assessing the impact of high-risk AI systems and implementing governance measures as needed.&lt;SEP&gt;Deployer refers to the entity that utilizes AI systems for various functions, with obligations under specific regulations regarding AI-generated content.&lt;SEP&gt;A deployer is a natural or legal person or authority using an AI system under its authority, excluding personal non-professional activity.</data>
  <data key="d3">chunk-93ef23a1d24ffc516addd681974bac32&lt;SEP&gt;chunk-a169417b09f70fa2792a3c9ce82a678d&lt;SEP&gt;chunk-51c94d77f328c85a261162f4664235f6</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019208</data>
  <data key="d6"></data>
</node>
<node id="Relevant Stakeholders">
  <data key="d0">Relevant Stakeholders</data>
  <data key="d1">concept</data>
  <data key="d2">Relevant stakeholders include representatives of affected groups and experts involved in assessing and governing AI systems.&lt;SEP&gt;Relevant stakeholders include business organizations, civil society organizations, academia, research organizations, trade unions, and consumer protection organizations involved in AI development.</data>
  <data key="d3">chunk-93ef23a1d24ffc516addd681974bac32&lt;SEP&gt;chunk-4996cfa66f0668d565cd83bbe46dd21a</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019208</data>
  <data key="d6"></data>
</node>
<node id="European Artificial Intelligence Office">
  <data key="d0">European Artificial Intelligence Office</data>
  <data key="d1">organization</data>
  <data key="d2">The European Artificial Intelligence Office (AI Office) develops templates for questionnaires to facilitate compliance with regulations.</data>
  <data key="d3">chunk-93ef23a1d24ffc516addd681974bac32</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019208</data>
  <data key="d6"></data>
</node>
<node id="Large Generative AI Models">
  <data key="d0">Large Generative AI Models</data>
  <data key="d1">concept</data>
  <data key="d2">Large generative AI models exemplify general-purpose AI models and allow flexible content generation.</data>
  <data key="d3">chunk-93ef23a1d24ffc516addd681974bac32</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019208</data>
  <data key="d6"></data>
</node>
<node id="Self-Supervised Learning">
  <data key="d0">Self-Supervised Learning</data>
  <data key="d1">method</data>
  <data key="d2">Self-supervised learning is a method used to train AI models on large amounts of data without explicit labeling.</data>
  <data key="d3">chunk-93ef23a1d24ffc516addd681974bac32</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019208</data>
  <data key="d6"></data>
