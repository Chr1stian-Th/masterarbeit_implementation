</node>
<node id="Transfer of Personal Data">
  <data key="d0">Transfer of Personal Data</data>
  <data key="d1">event</data>
  <data key="d2">The transfer of personal data involves moving data to third countries or international organizations under certain regulatory conditions.</data>
