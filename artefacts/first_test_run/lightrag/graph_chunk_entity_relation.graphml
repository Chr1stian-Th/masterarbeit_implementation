</node>
<node id="Right to Rectification">
  <data key="d0">Right to Rectification</data>
  <data key="d1">concept</data>
  <data key="d2">The Right to Rectification enables the data subject to request the correction of inaccurate personal data.</data>
  <data key="d3">chunk-ca37d7dbc74be645fc1de3e6e772a586</data>
  <data key="d4">unknown_source</data>
