  <data key="d0">Directive (EU) 2019/790</data>
  <data key="d1">concept</data>
  <data key="d2">Directive (EU) 2019/790 is a regulation established by the European Parliament and Council concerning copyright and related rights in the Digital Single Market.&lt;SEP&gt;Directive (EU) 2019/790 is a legal framework established by the European Parliament and Council governing copyright law in the context of AI model training and usage.</data>
  <data key="d3">chunk-bf9439294cd1ddefbd5a696360ace9e7&lt;SEP&gt;chunk-e128fa4453175248aac2b8414bc17643</data>
