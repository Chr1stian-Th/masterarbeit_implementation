  <data key="d0">Main Establishment</data>
  <data key="d1">concept</data>
  <data key="d2">Main Establishment refers to the central administrative location of a controller or processor in the Union, governing processing decisions regarding personal data across multiple Member States.</data>
  <data key="d3">chunk-b1184185c4bc8012fe969516fa45f07b</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018990</data>
