  <data key="d5">1773019211</data>
  <data key="d6"></data>
</node>
<node id="Human Intent">
  <data key="d0">Human Intent</data>
  <data key="d1">concept</data>
  <data key="d2">Human intent is the guiding principle that should align with the development and application of AI models, ensuring they operate within ethical and regulated boundaries.</data>
  <data key="d3">chunk-0a8f57272764fbaa96a8c14389c0661d</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019211</data>
  <data key="d6"></data>
</node>
<node id="Model Lifecycle">
  <data key="d0">Model Lifecycle</data>
  <data key="d1">concept</data>
  <data key="d2">The model lifecycle encompasses all stages of a general-purpose AI model's existence, influencing its potential systemic risks.</data>
  <data key="d3">chunk-0a8f57272764fbaa96a8c14389c0661d</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019211</data>
  <data key="d6"></data>
</node>
<node id="Compliance Obligations">
  <data key="d0">Compliance Obligations</data>
  <data key="d1">concept</data>
  <data key="d2">Compliance obligations are requirements that model providers must meet to align with regulatory standards regarding the use of general-purpose AI models.</data>
  <data key="d3">chunk-0a8f57272764fbaa96a8c14389c0661d</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019211</data>
  <data key="d6"></data>
</node>
<node id="Notifying Authority">
  <data key="d0">Notifying Authority</data>
  <data key="d1">organization</data>
  <data key="d2">The notifying authority is the national authority responsible for assessment procedures for conformity assessment bodies.&lt;SEP&gt;The notifying authority is responsible for notifying the Commission of any changes regarding the notified bodies.&lt;SEP&gt;The notifying authority verifies the status of certificates relevant to system suspensions or restrictions and determines the capability of notified bodies.</data>
  <data key="d3">chunk-6507d56efb6357f20f57227d44b681ea&lt;SEP&gt;chunk-f0714fdb65a0577bc4493dcb81d0a915&lt;SEP&gt;chunk-5e14a05a776d89b0f172b0c5789b0936&lt;SEP&gt;chunk-78ea54ae6ffd2850256fb7ad037b8474</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019211</data>
  <data key="d6"></data>
</node>
<node id="Certificates">
  <data key="d0">Certificates</data>
  <data key="d1">content</data>
  <data key="d2">Certificates are documents issued by notified bodies to confirm the conformity of assessed products or systems.&lt;SEP&gt;Certificates are official documents issued by notified bodies confirming compliance with relevant standards for AI systems.</data>
  <data key="d3">chunk-6507d56efb6357f20f57227d44b681ea&lt;SEP&gt;chunk-ff761b32d779286afb789136edfc0b4c</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019211</data>
  <data key="d6"></data>
</node>
<node id="Articles 29 and 30">
  <data key="d0">Articles 29 and 30</data>
  <data key="d1">concept</data>
  <data key="d2">Articles 29 and 30 detail the procedures that apply to extensions of the scope of notifications for notified bodies.</data>
  <data key="d3">chunk-6507d56efb6357f20f57227d44b681ea</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019211</data>
  <data key="d6"></data>
</node>
<node id="Restriction, Suspension or Withdrawal">
  <data key="d0">Restriction, Suspension or Withdrawal</data>
  <data key="d1">concept</data>
  <data key="d2">Restriction, suspension, or withdrawal refers to the actions that can be taken against a notified body if it no longer meets requirements.</data>
  <data key="d3">chunk-6507d56efb6357f20f57227d44b681ea</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019211</data>
  <data key="d6"></data>
