  <data key="d0">Group of Undertakings</data>
  <data key="d1">concept</data>
  <data key="d2">A group of undertakings consists of a controlling undertaking and its controlled undertakings, which share a centralized governance structure.&lt;SEP&gt;Group of Undertakings denotes a controlling entity along with its controlled entities.</data>
  <data key="d3">chunk-8e3626adc7cf865bec83f6479c1e08cb&lt;SEP&gt;chunk-b1184185c4bc8012fe969516fa45f07b</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018987</data>
  <data key="d6"></data>
</node>
<node id="Processing Activities">
  <data key="d0">Processing Activities</data>
  <data key="d1">concept</data>
  <data key="d2">Processing activities encompass all operations performed on personal data, including collection, storage, usage, and sharing.&lt;SEP&gt;Processing activities refer to operations performed on personal data, including collection, storage, and use, under the authority of the controller.</data>
  <data key="d3">chunk-8e3626adc7cf865bec83f6479c1e08cb&lt;SEP&gt;chunk-6ad40e7a844b107cf5d24e2adca46bdb</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018987</data>
  <data key="d6"></data>
