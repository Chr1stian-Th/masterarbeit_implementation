</node>
<node id="personal data">
  <data key="d0">personal data</data>
  <data key="d1">concept</data>
  <data key="d2">Personal data refers to any information relating to an identified or identifiable natural person, as addressed in various regulations.</data>
  <data key="d3">chunk-9b63383abdca30a6a477ed963f4766dc</data>
