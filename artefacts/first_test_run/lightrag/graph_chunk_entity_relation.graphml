  <data key="d4">unknown_source</data>
  <data key="d5">1773018989</data>
  <data key="d6"></data>
</node>
<node id="Personal Data Transfer">
  <data key="d0">Personal Data Transfer</data>
  <data key="d1">concept</data>
  <data key="d2">Personal data transfer refers to the process of transferring personal data to third countries or international organizations.</data>
  <data key="d3">chunk-65949aed6696e22716296aea9c7eb380</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018989</data>
