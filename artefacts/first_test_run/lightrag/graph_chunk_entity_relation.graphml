  <data key="d5">1773019223</data>
  <data key="d6"></data>
</node>
<node id="Articles 40">
  <data key="d0">Articles 40</data>
  <data key="d1">concept</data>
  <data key="d2">Article 40 refers to the use of harmonised standards within the Regulation.</data>
  <data key="d3">chunk-413f3509ccce7d84f0a2044eb12be69f</data>
