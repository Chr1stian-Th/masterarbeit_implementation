  <data key="d4">unknown_source</data>
  <data key="d5">1773018990</data>
  <data key="d6"></data>
</node>
<node id="Information Society Services">
  <data key="d0">Information Society Services</data>
  <data key="d1">concept</data>
  <data key="d2">Information society services refer to services provided via the internet and may require consideration of consent when collecting personal data from children.</data>
  <data key="d3">chunk-c09ea8bbba955df15eafbe1da5facb38</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018990</data>
  <data key="d6"></data>
</node>
<node id="Competent Supervisory Authority">
  <data key="d0">Competent Supervisory Authority</data>
  <data key="d1">organization</data>
  <data key="d2">The Competent Supervisory Authority is responsible for accrediting bodies that monitor compliance with the code of conduct and ensuring adherence to regulations.&lt;SEP&gt;The Competent Supervisory Authority oversees the certification bodies and ensures compliance with data protection regulations.&lt;SEP&gt;The Competent Supervisory Authority is an authorized body that oversees data protection compliance and can grant authorizations for data transfers.</data>
  <data key="d3">chunk-6fb6a4af737980e04056c2522ea213fe&lt;SEP&gt;chunk-39551a1dbe3cdde38b22607932e0688f&lt;SEP&gt;chunk-5ab41d6ec0d1446be5ba58c1ab5b423c</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018990</data>
  <data key="d6"></data>
</node>
<node id="Infringement of the Code">
  <data key="d0">Infringement of the Code</data>
  <data key="d1">event</data>
  <data key="d2">Infringement of the Code refers to violations of the established Code of Conduct that warrant action from the Competent Supervisory Authority.</data>
  <data key="d3">chunk-6fb6a4af737980e04056c2522ea213fe</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018990</data>
  <data key="d6"></data>
</node>
<node id="European Data Protection Seal">
  <data key="d0">European Data Protection Seal</data>
  <data key="d1">concept</data>
  <data key="d2">The European Data Protection Seal is a common certification that indicates compliance with data protection criteria approved by the Board.&lt;SEP&gt;The European Data Protection Seal is a common certification resulting from approved criteria by the Board for data protection compliance.</data>
  <data key="d3">chunk-6fb6a4af737980e04056c2522ea213fe&lt;SEP&gt;chunk-39551a1dbe3cdde38b22607932e0688f</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018990</data>
  <data key="d6"></data>
</node>
