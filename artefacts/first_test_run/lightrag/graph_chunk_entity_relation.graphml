  <data key="d0">Scientific Community</data>
  <data key="d1">concept</data>
  <data key="d2">The scientific community comprises experts engaged in research and development related to AI technologies and their implications.</data>
  <data key="d3">chunk-d97d0e266280dff1c105fac7dc08fc5d</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019211</data>
