</node>
<node id="Safety Component">
  <data key="d0">Safety Component</data>
  <data key="d1">concept</data>
  <data key="d2">A safety component is part of a product or AI system that functions to ensure safety, failing which can endanger health and safety.</data>
  <data key="d3">chunk-5e14a05a776d89b0f172b0c5789b0936</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773019223</data>
