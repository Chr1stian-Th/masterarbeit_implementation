  <data key="d1">concept</data>
  <data key="d2">Internet protocol addresses are numeric labels assigned to devices connected to a computer network, which may be linked to natural persons.</data>
  <data key="d3">chunk-f4dfe3f1190ff8cf7dc9f62b85bed40a</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018987</data>
  <data key="d6"></data>
</node>
<node id="Cookie Identifiers">
  <data key="d0">Cookie Identifiers</data>
  <data key="d1">concept</data>
  <data key="d2">Cookie identifiers are small pieces of data stored on the user's device to identify the user and track their activities online.</data>
  <data key="d3">chunk-f4dfe3f1190ff8cf7dc9f62b85bed40a</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018987</data>
  <data key="d6"></data>
</node>
<node id="Radio Frequency Identification Tags">
  <data key="d0">Radio Frequency Identification Tags</data>
  <data key="d1">concept</data>
  <data key="d2">Radio frequency identification tags are technology used to wirelessly identify and track tags attached to objects, which can be linked to natural persons.</data>
  <data key="d3">chunk-f4dfe3f1190ff8cf7dc9f62b85bed40a</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018987</data>
  <data key="d6"></data>
</node>
<node id="Article 15">
  <data key="d0">Article 15</data>
  <data key="d1">concept</data>
  <data key="d2">Article 15 outlines the right of access by the data subject regarding personal data processing.&lt;SEP&gt;Article 15 outlines the requirements for high-risk AI systems regarding their accuracy, robustness, and cybersecurity.</data>
  <data key="d3">chunk-ca37d7dbc74be645fc1de3e6e772a586&lt;SEP&gt;chunk-e20d35aae57ccfd5ec58ef7772f98c17</data>
