<node id="Fundamental Rights Agency">
  <data key="d0">Fundamental Rights Agency</data>
  <data key="d1">organization</data>
  <data key="d2">The Fundamental Rights Agency is involved in ensuring that AI systems comply with fundamental rights and ethical standards.&lt;SEP&gt;The Fundamental Rights Agency is a permanent member of the Advisory Forum, contributing to discussions on AI regulations.</data>
  <data key="d3">chunk-df0cf5bee4370453cb38606bad89b764&lt;SEP&gt;chunk-d5a5973b039f9a9af3e3e9d93b392c66</data>
