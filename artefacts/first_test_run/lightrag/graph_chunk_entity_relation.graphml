<node id="Right to Access">
  <data key="d0">Right to Access</data>
  <data key="d1">concept</data>
  <data key="d2">The Right to Access allows the data subject to obtain confirmation whether their personal data is being processed.</data>
  <data key="d3">chunk-ca37d7dbc74be645fc1de3e6e772a586</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018987</data>
