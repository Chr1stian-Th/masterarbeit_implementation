<node id="Criminal Convictions">
  <data key="d0">Criminal Convictions</data>
  <data key="d1">concept</data>
  <data key="d2">Criminal convictions relate to the formal verdicts with respect to persons found guilty of crimes, which involves specific data processing regulations.</data>
  <data key="d3">chunk-40ecaa725d6d1bc748899703ed8b84dc</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018991</data>
