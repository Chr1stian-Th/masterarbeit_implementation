  <data key="d0">Representative</data>
  <data key="d1">concept</data>
  <data key="d2">Representative is defined as a designated natural or legal person in the Union who acts on behalf of a controller or processor to ensure compliance with regulations.</data>
  <data key="d3">chunk-b1184185c4bc8012fe969516fa45f07b</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773018990</data>
