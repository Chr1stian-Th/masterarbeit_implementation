  <data key="d0">Clinical Treatment</data>
  <data key="d1">concept</data>
  <data key="d2">Clinical treatment refers to the healthcare provided to a natural person for managing their health issues.</data>
  <data key="d3">chunk-8e3626adc7cf865bec83f6479c1e08cb</data>
  <data key="d4">unknown_source</data>
