  <data key="d13"></data>
</edge>
<edge source="Data Subject" target="Article 21">
  <data key="d7">2.0</data>
  <data key="d8">The Data Subject can object to processing as outlined in Article 21, asserting their legal rights.&lt;SEP&gt;Article 21 allows the Data Subject to object to the processing of their personal data based on specific concerns.</data>
  <data key="d9">data rights,legal grounds,objection,objection rights</data>
  <data key="d10">chunk-2016931a6e14615018d3d7f8304b6a1e&lt;SEP&gt;chunk-9d92eec8ceb3813d55e2b578c5604f24</data>
